{
  "name": "personal-assistant",
  "version": "2.8.4",
  "description": "An plugin which help you to automatically manage Obsidian.",
  "main": "main.js",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "dev:tailwind": "BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./src/custom.pcss -o ./styles.css --watch",
    "tailwind:build": "BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./src/custom.pcss -o ./styles.css --minify",
    "build": "tsc -noEmit -skipLibCheck && BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./src/custom.pcss -o ./styles.css --minify && node --no-warnings=ExperimentalWarning esbuild.config.mjs production",
    "changelog": "node scripts/changelog.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "version": "node version-bump.mjs && git add manifest-beta.json manifest.json versions.json CHANGELOG.md",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"__mocks__/**/*.ts\"",
    "eval:pa:fast": "jest --runTestsByPath __tests__/pa-eval.test.ts --runInBand",
    "generate:third-party-notices": "node scripts/generate-third-party-notices.mjs",
    "check:third-party-notices": "node scripts/check-third-party-notices.mjs",
    "audit:bundle": "node scripts/audit-bundle.mjs --input dist/main.js --allow-node-builtins",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "release:publish": "node scripts/publish-release.mjs",
    "test": "jest"
  },
  "keywords": [],
  "author": "edonyzpc",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@codemirror/commands": "^6.1.2",
    "@codemirror/language": "https://github.com/lishid/cm-language",
    "@codemirror/search": "^6.2.2",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@eslint/js": "10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "esbuild": "^0.28.1",
    "esbuild-plugin-copy": "2.1.1",
    "eslint": "10.2.1",
    "jest": "^30.3.0",
    "obsidian": "1.12.3",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.9",
    "tslib": "2.8.1",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@langchain/core": "1.2.3",
    "@langchain/openai": "1.4.4",
    "@langchain/textsplitters": "1.0.1",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "chart.js": "^4.4.4",
    "fflate": "^0.8.3",
    "ldrs": "^1.1.7",
    "nanoid": "^5.0.7",
    "obsidian-callout-manager": "^1.0.2-alpha1",
    "react": "18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "18.3.1",
    "semver": "^7.5.2",
    "zod": "3.25.76"
  }
}
