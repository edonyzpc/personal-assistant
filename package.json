{
  "name": "personal-assistant",
  "version": "1.11.0",
  "description": "An plugin which help you to automatically manage Obsidian.",
  "main": "main.js",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "dev:tailwind": "tailwindcss -i ./src/custom.css -o ./styles.css --watch",
    "tailwind:build": "tailwindcss -i ./src/custom.css -o ./styles.css --minify",
    "build": "tsc -noEmit -skipLibCheck && tailwindcss -i ./src/custom.css -o ./styles.css --minify && node --no-warnings=ExperimentalWarning esbuild.config.mjs production",
    "changelog": "node scripts/changelog.mjs",
    "version": "node version-bump.mjs && git add manifest-beta.json manifest.json versions.json CHANGELOG.md",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"__mocks__/**/*.ts\"",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "release:publish": "node scripts/publish-release.mjs",
    "test": "jest"
  },
  "keywords": [],
  "author": "edonyzpc",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/commands": "^6.1.2",
    "@codemirror/language": "https://github.com/lishid/cm-language",
    "@codemirror/search": "^6.2.2",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@eslint/js": "10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "esbuild": "0.25.5",
    "esbuild-plugin-copy": "2.1.1",
    "eslint": "10.2.1",
    "fflate": "^0.8.3",
    "jest": "^30.3.0",
    "obsidian": "1.12.3",
    "tailwindcss": "^3.4.15",
    "ts-jest": "^29.4.9",
    "tslib": "2.8.1",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@floating-ui/core": "^1.6.8",
    "@langchain/classic": "1.0.31",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "1.1.41",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "1.4.4",
    "@langchain/textsplitters": "1.0.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@sqliteai/sqlite-wasm": "3.50.4-sync.0.8.30-vector.0.9.23",
    "chart.js": "^4.4.4",
    "ldrs": "^1.1.7",
    "nanoid": "^5.0.7",
    "obsidian-callout-manager": "^1.0.2-alpha1",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "semver": "^7.5.2",
    "vanilla-picker": "2.12.3"
  }
}
