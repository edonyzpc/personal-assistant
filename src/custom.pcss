@tailwind components;
@tailwind utilities;

body {
	--status-bar: #2fcc70ee;
	--status-bar-animate: #2fcc70;
	--status-bar-animate-shadow: #0280ff;
	--status-bar-hover: #9e2ff9;
	--status-bar-ai: #0544ff;
	--status-bar-ai-breathing: #ac05ff;
	--status-bar-ai-hover: #ff0101;
	--status-bar-ai-warning: #f59e0b;
	--status-bar-ai-unavailable: #ef4444;
}

.theme-light {
	--pa-text-normal: rgb(198, 208, 245);
	--pa-background-primary: rgb(30, 30, 46);
	--pa-record-font-color: #000000;
	--pa-record-background-color: #ffffff;
}

.theme-dark {
	--pa-text-normal: #e1e7fe;
	--pa-background-primary: #1e1e2e;
	--pa-record-font-color: #e1e7fe;
	--pa-record-background-color: #1e1e2e;
}

.pa-statistics-view {
	--pa-stat-tab-text: var(--text-muted);
	--pa-stat-tab-hover-bg: var(--background-modifier-hover);
	--pa-stat-tab-hover-text: var(--text-normal);
	--pa-stat-tab-active-bg: var(--background-primary);
	--pa-stat-tab-active-text: var(--text-normal);
	--pa-stat-tab-active-shadow: 0 1px 2px 0 rgba(15, 23, 42, 0.08);
	--pa-stat-chart-text: var(--text-muted);
	--pa-stat-chart-grid: var(--background-modifier-border);
	--pa-stat-chart-bar-bg: rgba(225, 29, 72, 0.35);
	--pa-stat-chart-bar-border: rgb(225, 29, 72);
	--pa-stat-chart-line-purple-bg: rgba(147, 51, 234, 0.14);
	--pa-stat-chart-line-purple-border: rgb(147, 51, 234);
	--pa-stat-chart-line-teal-bg: rgba(20, 184, 166, 0.16);
	--pa-stat-chart-line-teal-border: rgb(13, 148, 136);
	--pa-stat-chart-line-amber-bg: rgba(234, 179, 8, 0.18);
	--pa-stat-chart-line-amber-border: rgb(202, 138, 4);
	--pa-stat-chart-y-tick: rgb(225, 29, 72);
	--pa-stat-chart-y1-tick: rgb(147, 51, 234);
	background-color: var(--background-secondary);
	color: var(--text-normal);
}

.pa-stat-card {
	background-color: var(--background-primary);
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
	box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.pa-stat-header {
	background-color: var(--background-primary);
	border-bottom: 1px solid var(--background-modifier-border);
}

.pa-stat-metric-label {
	color: var(--text-muted);
	font-size: 0.75rem;
	font-weight: 500;
	letter-spacing: 0.025em;
	text-transform: uppercase;
}

.pa-stat-metric-value {
	color: var(--text-normal);
	font-weight: 600;
}

.pa-stat-text-secondary {
	color: var(--text-muted);
}

.pa-stat-segment-bg {
	background-color: var(--background-secondary-alt);
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
}

.pa-stat-range-bg {
	background-color: var(--background-primary);
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
}

.pa-stat-warning {
	background-color: rgba(245, 158, 11, 0.08);
	border: 1px solid rgba(245, 158, 11, 0.3);
	border-radius: 6px;
	color: var(--text-normal);
}

.pa-stat-progress-track {
	background-color: var(--background-secondary-alt);
}

.pa-statistics-segment {
	background-clip: padding-box;
}

.pa-statistics-segment--views {
	--pa-stat-tab-active-bg: var(--background-primary);
	--pa-stat-tab-active-text: var(--text-normal);
	--pa-stat-tab-active-shadow: 0 1px 2px 0 rgba(15, 23, 42, 0.08);
}

.theme-dark .pa-statistics-segment--views {
	--pa-stat-tab-active-bg: var(--background-primary-alt);
	--pa-stat-tab-active-text: var(--text-normal);
	--pa-stat-tab-active-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.2);
}

.pa-statistics-segment--range {
	--pa-stat-tab-active-bg: var(--interactive-accent);
	--pa-stat-tab-active-text: var(--text-on-accent);
	--pa-stat-tab-active-shadow: none;
}

.pa-statistics-view .pa-statistics-segment > .pa-statistics-tab {
	appearance: none;
	background-clip: padding-box;
	background-color: transparent;
	background-image: none;
	border: 0;
	border-radius: 4px;
	box-shadow: none;
	color: var(--pa-stat-tab-text);
	cursor: pointer;
	flex: 0 0 auto;
	font-size: 0.875rem;
	font-weight: 500;
	line-height: 1.25rem;
	margin: 0;
	min-height: 2.75rem;
	padding: 0.375rem 0.75rem;
	text-align: center;
	white-space: nowrap;
}

.pa-statistics-view .pa-statistics-segment > .pa-statistics-tab:hover {
	background-color: var(--pa-stat-tab-hover-bg);
	color: var(--pa-stat-tab-hover-text);
}

.pa-statistics-view .pa-statistics-segment > .pa-statistics-tab[data-active="true"] {
	background-color: var(--pa-stat-tab-active-bg);
	box-shadow: var(--pa-stat-tab-active-shadow);
	color: var(--pa-stat-tab-active-text);
}

.pa-statistics-view .pa-statistics-segment > .pa-statistics-tab:focus-visible {
	box-shadow:
		0 0 0 2px var(--background-primary),
		0 0 0 4px var(--interactive-accent);
	outline: none;
}

.pa-statistics-composition-progress {
	background: transparent;
	border: 0;
	border-radius: 4px;
	display: block;
	height: 100%;
	overflow: hidden;
	position: relative;
	width: 100%;
}

.pa-statistics-composition-progress-fill {
	background: currentColor;
	border-radius: 4px;
	display: block;
	height: 100%;
	width: var(--pa-statistics-composition-progress-width, 0%);
}

.pa-statistics-composition-progress.pa-bg-teal-500 {
	background: transparent;
	color: rgb(20, 184, 166);
}

.pa-statistics-composition-progress.pa-bg-rose-500 {
	background: transparent;
	color: rgb(244, 63, 94);
}

.pa-statistics-composition-progress.pa-bg-purple-500 {
	background: transparent;
	color: rgb(168, 85, 247);
}

.pa-statistics-composition-progress.pa-bg-amber-500 {
	background: transparent;
	color: rgb(245, 158, 11);
}

.personal-assistant-statusbar:hover {
	color: var(--status-bar-hover);
}

.personal-assistant-statusbar {
	order: 1;
	color: var(--status-bar);
}

.personal-assistant-statusbar-breathing {
	animation: svg-blink 2s infinite;
	opacity: 1;
}

.personal-assistant-ai-statusbar:hover svg {
	color: var(--status-bar-ai-hover);
}

.personal-assistant-ai-statusbar svg {
	order: 1;
	color: var(--status-bar-ai);
}

.personal-assistant-ai-statusbar-ready svg,
.personal-assistant-ai-statusbar-done svg {
	order: 1;
	color: var(--status-bar);
}

.personal-assistant-ai-statusbar-needs-update svg {
	order: 1;
	color: var(--status-bar-ai-warning);
}

.personal-assistant-ai-statusbar-needs-setup svg {
	order: 1;
	color: var(--status-bar-ai);
}

.personal-assistant-ai-statusbar-unavailable svg {
	order: 1;
	color: var(--status-bar-ai-unavailable);
}

.personal-assistant-ai-breathing {
	animation: svg-blink-ai 2s infinite;
	opacity: 1;
}

.personal-assistant-ai-breathing svg {
	order: 1;
	color: var(--status-bar-ai);
}

@keyframes svg-blink {
	0% {
		opacity: 1;
		color: var(--status-bar-animate);
	}

	50% {
		opacity: 0.8;
		transform: scale(0.8);
		filter: drop-shadow(6px 6px 10px var(--status-bar-animate-shadow));
		color: var(--status-bar);
	}

	100% {
		opacity: 1;
		color: var(--status-bar-animate);
	}
}

@keyframes svg-blink-ai {
	0% {
		opacity: 1;
		color: var(--status-bar-animate);
	}

	50% {
		opacity: 0.6;
		transform: scale(0.9);
		filter: drop-shadow(6px 6px 10px var(--status-bar-animate-shadow));
		color: var(--status-bar);
	}

	100% {
		opacity: 1;
		color: var(--status-bar-animate);
	}
}

#svg-animate {
	filter: drop-shadow(6px 6px 10px var(--status-bar-animate));
}

.plugin-switch-on-off-svg {
	top: 0.24em;
	position: relative;
	margin-right: 4px;
}

.pa-batch-modal-title {
	text-align: center;
}

.resize-popover-width {
	--popover-width: var(--resize-popover-width);
}

.pa-plugin-suggestion-name {
	color: var(--text-normal);
}

.plugin-update-svg {
	position: relative;
	margin-right: 4px;
	align-self: center;
}

.progress-bar-notice .meter {
	box-sizing: content-box;
	height: 14px;
	position: relative;
	margin: 1px 0 1px 0;
	background: rgb(122, 122, 122);
	border-radius: 9px;
	padding: 1px;
	box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.3);
	text-align: left;
	font-family: "Courier New", "Comic Mono";
	font-size: 13px;
	font-style: oblique 40deg;
	width: auto;
}

.progress-bar-notice .meter > span {
	display: block;
	height: 100%;
	border-top-right-radius: 20px;
	border-bottom-right-radius: 20px;
	border-top-left-radius: 20px;
	border-bottom-left-radius: 20px;
	background-color: rgb(43, 194, 83);
	background-image: linear-gradient(
		center bottom,
		rgb(43, 194, 83) 37%,
		rgb(84, 240, 84) 69%
	);
	box-shadow: inset 0 2px 9px rgba(255, 255, 255, 0.3),
		inset 0 -2px 6px rgba(0, 0, 0, 0.4);
	position: relative;
	overflow: hidden;
	width: auto;
}

.progress-bar-notice .meter > span:after,
.progress-bar-notice .animate > span > span {
	content: "";
	position: absolute;
	top: 0;
	left: 0;
	bottom: 0;
	right: 0;
	background-image: linear-gradient(
		-45deg,
		rgba(255, 255, 255, 0.2) 25%,
		transparent 25%,
		transparent 50%,
		rgba(255, 255, 255, 0.2) 50%,
		rgba(255, 255, 255, 0.2) 75%,
		transparent 75%,
		transparent
	);
	z-index: 1;
	background-size: 40px 40px;
	animation: move 4s linear infinite;
	border-top-right-radius: 20px;
	border-bottom-right-radius: 20px;
	border-top-left-radius: 20px;
	border-bottom-left-radius: 20px;
	overflow: hidden;
	width: auto;
}

.progress-bar-notice .animate > span:after {
	display: none;
}

@keyframes move {
	0% {
		background-position: 0 0;
	}

	100% {
		background-position: 40px 40px;
	}
}

.progress-bar-notice .orange > span {
	background-image: linear-gradient(#f1a165, #f36d0a);
}

.progress-bar-notice .red > span {
	background-image: linear-gradient(#f0a3a3, #f42323);
}

.progress-bar-notice .nostripes > span > span,
.progress-bar-notice .nostripes > span::after {
	background-image: none;
}

.progress-bar-grid {
	display: grid;
	grid-template-columns: 9fr 1fr;
	gap: 0 8px;
	margin-bottom: 8px;
	width: 100%;
}

.progress-bar-number {
	color: rgba(84, 240, 84, 0.69);
	width: 41px;
}

.progress-bar-items-error {
	color: red;
}

.progress-bar-notice {
	max-width: 480px;
	background-color: var(--pa-background-primary);
}

.progress-bar-items-grid {
	display: grid;
	grid-template-columns: 18px 9fr;
	grid-template-rows: repeat(auto-fill, 37px);
	gap: 0 8px;
}

.progress-bar-items-text {
	color: var(--pa-text-normal);
	display: inline-block;
	height: 18px;
	align-self: center;
}

.pa-notice-shell {
	background-color: var(--pa-background-primary);
}

.pa-ai-featured-image-progress-rule {
	margin: unset;
}

.recordlist-wrapper div.callout[data-callout="abstract"] {
	--callout-icon: loader;
	--callout-color: rgb(34, 152, 225);
}

.pa-record-wrapper-clickable {
	cursor: pointer;
}

.pa-recordlist-reading-view {
	height: 100%;
	width: 100%;
}

.pa-recordlist-preview-view {
	tab-size: 4;
}

.pa-recordlist-preview-pusher {
	height: 0.1px;
	margin-bottom: 0;
	width: 1px;
}

.callout[data-callout="personal-assistant"] {
	--callout-color: 34, 152, 225;
	--callout-icon: '<svg viewBox="0 0 100 100"><svg xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" width="100" height="100" viewBox="0 0 172 172"><g fill="currentColor" fill-rule="nonzero" stroke="none" stroke-width="1" stroke-linecap="butt" stroke-linejoin="miter" stroke-miterlimit="10" stroke-dasharray="" stroke-dashoffset="0" font-family="none" font-weight="none" font-size="none" text-anchor="none" style="mix-blend-mode: normal"><path d="M0,172v-172h172v172z" fill="none"></path><g id="svg-animate" fill="currentColor"><path d="M53.75,21.5c-8.27246,0 -14.86523,5.20703 -18.39257,12.09375c-8.39844,1.76368 -15.91504,6.84473 -19.31641,15.03321c-6.50879,15.5371 -16.04102,41.53027 -16.04102,64.24804c0,20.70215 16.92285,37.625 37.625,37.625c14.90723,0 27.75683,-8.86035 33.84571,-21.5h29.05859c6.08886,12.63965 18.93847,21.5 33.8457,21.5c20.70215,0 37.625,-16.92285 37.625,-37.625c0,-8.44043 -2.60351,-19.44239 -5.87891,-30.90625c-3.31739,-11.50585 -7.39062,-23.26367 -10.58203,-32.08203c-3.10742,-8.44043 -10.41406,-13.85742 -18.77051,-15.99902c-3.48534,-7.05469 -10.12011,-12.3877 -18.51855,-12.3877c-7.68457,0 -13.73145,4.61915 -17.51074,10.75h-29.47852c-3.77929,-6.13085 -9.82617,-10.75 -17.51074,-10.75zM53.75,32.25c4.70313,0 8.6084,3.02344 10.07813,7.18067l1.25977,3.56933h41.82422l1.25976,-3.56933c1.46973,-4.15723 5.375,-7.18067 10.07813,-7.18067c4.8291,0 8.77636,3.19141 10.16211,7.5166l1.00781,3.14942l3.27539,0.50391c5.87891,0.92382 10.70801,4.61914 12.76563,10.1621c2.81348,7.72656 6.21484,17.7627 9.19629,27.71484c-5.87891,-3.77929 -12.80761,-6.04687 -20.28223,-6.04687c-14.90723,0 -27.75683,8.86035 -33.8457,21.5h-29.05859c-6.08888,-12.63965 -18.93848,-21.5 -33.84571,-21.5c-8.18848,0 -15.74707,2.72949 -21.91992,7.22266c3.06543,-11.21192 7.01269,-21.87793 10.24609,-29.68848c2.22558,-5.375 7.22266,-8.86034 13.10156,-9.49023l3.44335,-0.37793l1.0918,-3.2754c1.42773,-4.2832 5.375,-7.39062 10.1621,-7.39062zM37.625,86c14.90723,0 26.875,11.96777 26.875,26.875c0,14.90723 -11.96777,26.875 -26.875,26.875c-14.90723,0 -26.875,-11.96777 -26.875,-26.875c0,-14.90723 11.96777,-26.875 26.875,-26.875zM134.375,86c14.90723,0 26.875,11.96777 26.875,26.875c0,14.90723 -11.96777,26.875 -26.875,26.875c-14.90723,0 -26.875,-11.96777 -26.875,-26.875c0,-14.90723 11.96777,-26.875 26.875,-26.875zM74.7041,107.5h22.59179c-0.25195,1.76368 -0.5459,3.52734 -0.5459,5.375c0,1.84766 0.29395,3.61133 0.5459,5.375h-22.59179c0.25195,-1.76367 0.5459,-3.52734 0.5459,-5.375c0,-1.84766 -0.29395,-3.61132 -0.5459,-5.375z"></path></g></g></svg></svg>';
}

.callout[data-callout="personal-assistant-ai"] {
	--callout-color: 34, 152, 225;
	--callout-icon: '<svg viewBox="0 0 100 100"><svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bot-icon lucide-bot"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg></svg>';
}

.popover.resize-popover-width .popover-content {
	width: var(--resize-popover-width);
}

#modulz-log-icon path {
	fill: #ce7aa5;
}

#ai-robot-selected-item {
	color: #868686;
	font-size: 14px;
}

.llm-modal,
.pa-chat-modal {
	padding: 20px;
	max-width: 800px;
	margin: 0 auto;
}

.llm-modal h2,
.pa-chat-modal h2 {
	margin-bottom: 20px;
	text-align: center;
	font-size: 1.8em;
	color: var(--text-normal);
}

.pa-chat-confirmation-modal button.mod-warning,
.pa-chat-confirmation-modal button.mod-destructive {
	background-color: color-mix(in srgb, var(--text-error, #ef4444) 14%, var(--background-primary));
	border-color: color-mix(in srgb, var(--text-error, #ef4444) 22%, transparent);
	color: var(--text-error, #ef4444);
}

.pa-chat-confirmation-modal button.mod-warning:hover,
.pa-chat-confirmation-modal button.mod-warning:focus-visible,
.pa-chat-confirmation-modal button.mod-destructive:hover,
.pa-chat-confirmation-modal button.mod-destructive:focus-visible {
	background-color: color-mix(in srgb, var(--text-error, #ef4444) 86%, #7f1d1d);
	border-color: color-mix(in srgb, var(--text-error, #ef4444) 80%, #7f1d1d);
	color: var(--text-on-accent, #ffffff);
}

.pa-chat-confirmation-modal button.mod-warning:active,
.pa-chat-confirmation-modal button.mod-destructive:active {
	background-color: color-mix(in srgb, var(--text-error, #ef4444) 72%, #7f1d1d);
	border-color: color-mix(in srgb, var(--text-error, #ef4444) 72%, #7f1d1d);
	color: var(--text-on-accent, #ffffff);
}

.pa-chat-history-modal-shell {
	box-sizing: border-box;
	width: min(720px, calc(100vw - 32px));
	max-width: calc(100vw - 32px);
	overflow-x: hidden;
}

.pa-chat-history-modal {
	box-sizing: border-box;
	max-width: 100%;
	overflow-x: hidden;
}

.pa-chat-history-list {
	display: flex;
	flex-direction: column;
	gap: 8px;
	list-style: none;
	margin: 16px 0 20px;
	max-width: 100%;
	overflow-x: hidden;
	padding: 0;
}

.pa-chat-history-item {
	display: grid;
	grid-template-columns: minmax(0, 1fr) 44px;
	align-items: center;
	gap: 8px;
	max-width: 100%;
	min-width: 0;
}

.pa-chat-history-open {
	box-sizing: border-box;
	display: grid;
	gap: 4px;
	justify-items: start;
	max-width: 100%;
	min-width: 0;
	overflow: hidden;
	text-align: left;
	width: 100%;
}

.pa-chat-history-title,
.pa-chat-history-preview,
.pa-chat-history-meta {
	display: block;
	max-width: 100%;
	min-width: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.pa-chat-history-delete {
	align-items: center;
	align-self: center;
	display: inline-flex;
	height: 44px;
	justify-content: center;
	justify-self: end;
	min-width: 44px;
	padding: 0;
	width: 44px;
}

body.is-mobile .pa-chat-history-modal-shell {
	width: min(520px, calc(100vw - 24px));
	max-width: calc(100vw - 24px);
}

/* ── Chat namespace migration (llm-* -> pa-chat-*) ──
   Dual-class aliases for backward compatibility. The old llm-* classes
   remain; the new pa-chat-* classes are added in chat-view.ts alongside
   them. Since child selectors like `.llm-view .thinking-status` match
   as long as the ancestor has `llm-view`, no nested selectors need
   duplicating. Full removal of llm-* deferred to next major version.

   Mapping:
     llm-view            -> pa-chat-view
     llm-chat-container  -> pa-chat-container
     llm-input           -> pa-chat-input
     llm-message         -> pa-chat-message
     llm-message-enter   -> pa-chat-message-enter
     llm-buttons         -> pa-chat-buttons
     llm-modal           -> pa-chat-modal                             */

.llm-view {
	--pa-chat-role-identicon-yellow: #f6c445;
	--pa-chat-role-identicon-orange: #f97316;
	--pa-chat-role-identicon-red: #ef4444;
	--pa-chat-role-identicon-purple: #8b5cf6;
	--pa-chat-role-identicon-blue: #3b82f6;
	--pa-chat-status-bar-clearance: 0px;
	--pa-chat-keyboard-clearance: 0px;
	--pa-chat-keyboard-accessory-clearance: 0px;
	--pa-chat-keyboard-offset: 0px;
	--pa-chat-composer-height: 0px;
	--pa-chat-keyboard-motion: 180ms cubic-bezier(0.22, 1, 0.36, 1);
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
	height: 100%;
	min-height: 0;
	overflow: hidden;
	padding: 0 0 var(--pa-chat-keyboard-clearance, 0px);
	position: relative;
	background: var(--background-primary);
}

body.is-mobile .llm-view {
	padding-bottom: 0;
}

/* ── Chat view host containers ──
   Obsidian wraps the view in .workspace-leaf-content on desktop;
   on mobile it adds .workspace-drawer-inner (with padding that exposes
   a different background), .workspace-drawer-header (top bar), and
   .workspace-drawer-tab-container (bottom tab switcher).
   Unify all host containers to --background-primary so the chat body
   blends seamlessly across all themes. Scoped via a runtime host class
   so other drawer tabs are unaffected. */
body.is-mobile .workspace-leaf-content.workspace-leaf-content[data-type="sidellm-view"] {
	background: var(--background-primary);
}
.workspace-drawer-inner.pa-chat-drawer-host {
	background: var(--background-primary);
	padding-bottom: max(6px, env(safe-area-inset-bottom, 6px));
}

body.is-mobile .workspace-drawer-inner.pa-chat-drawer-host {
	--pa-chat-drawer-top-clearance: clamp(10px, calc(env(safe-area-inset-top, 0px) - 24px), 24px);
	padding-top: var(--pa-chat-drawer-top-clearance);
}

.workspace-drawer-inner.pa-chat-drawer-host > .workspace-drawer-header {
	display: none;
}
.workspace-drawer-inner.pa-chat-drawer-host > .workspace-drawer-tab-container {
	background: var(--background-primary);
}

/* ── Mobile tab bar auto-hide ── */
.workspace-drawer-inner.pa-chat-drawer-host .workspace-drawer-tab-options {
	max-height: 0;
	padding-top: 0;
	padding-bottom: 0;
	overflow: hidden;
	opacity: 0;
	pointer-events: none;
	transition: max-height 0.2s ease, padding 0.2s ease, opacity 0.2s ease;
}
.workspace-drawer-inner.pa-chat-drawer-host .workspace-drawer-tab-options.pa-tab-bar-visible {
	max-height: 60px;
	padding-top: 4px;
	padding-bottom: 4px;
	overflow: visible;
	opacity: 1;
	pointer-events: auto;
	transition: max-height 0.2s ease, padding 0.2s ease, opacity 0.2s ease;
}
.pa-tab-bar-handle {
	display: flex;
	align-items: center;
	justify-content: center;
	min-height: 44px;
	padding: 12px 0;
	opacity: 0.5;
	color: var(--text-muted);
	cursor: pointer;
	-webkit-tap-highlight-color: transparent;
	flex-shrink: 0;
}
.pa-tab-bar-handle:active {
	opacity: 0.85;
}
.pa-tab-bar-handle svg {
	width: 20px;
	height: 20px;
}

body.is-mobile .pa-tab-bar-handle {
	--pa-tab-bar-handle-color: color-mix(in srgb, var(--text-normal) 72%, var(--text-muted));
	--pa-tab-bar-handle-expanded-color: color-mix(in srgb, var(--interactive-accent) 78%, var(--text-normal));
	position: relative;
	min-height: 20px;
	padding: 0;
	color: var(--pa-tab-bar-handle-color);
	opacity: 0.82;
}

body.theme-light.is-mobile .pa-tab-bar-handle {
	--pa-tab-bar-handle-color: color-mix(in srgb, var(--text-normal) 76%, var(--text-muted));
}

body.theme-dark.is-mobile .pa-tab-bar-handle {
	--pa-tab-bar-handle-color: color-mix(in srgb, var(--text-normal) 82%, var(--text-muted));
}

body.is-mobile .pa-tab-bar-handle[aria-expanded="true"] {
	color: var(--pa-tab-bar-handle-expanded-color);
	opacity: 0.92;
}

body.is-mobile .pa-tab-bar-handle::before {
	content: "";
	position: absolute;
	inset: -10px 0;
}

body.is-mobile .pa-tab-bar-handle svg {
	width: 14px;
	height: 14px;
	stroke-width: 2.4px;
}

.pa-chat-keyboard-spacer {
	display: none;
	flex: 0 0 0px;
	height: 0;
	min-height: 0;
	contain: layout paint size;
	pointer-events: none;
}

body.is-mobile .pa-chat-keyboard-spacer {
	display: block;
	flex-basis: var(--pa-chat-keyboard-clearance, 0px);
	height: var(--pa-chat-keyboard-clearance, 0px);
}

body.is-mobile .llm-view.is-keyboard-open .pa-chat-keyboard-spacer {
	flex-basis: var(--pa-chat-keyboard-clearance, 0px);
	height: var(--pa-chat-keyboard-clearance, 0px);
}

body.is-mobile .llm-view.is-keyboard-open .pa-tab-bar-handle {
	min-height: 12px;
}

body.is-mobile .llm-view.is-keyboard-open .pa-tab-bar-handle svg {
	width: 11px;
	height: 11px;
}

.llm-chat-container {
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
	flex: 1 1 auto;
	min-height: 0;
	min-width: 0;
	width: 100%;
	overflow-x: hidden;
	overflow-y: auto;
	overscroll-behavior-x: none;
	overscroll-behavior-y: contain;
	padding: 14px;
	border-bottom: 1px solid var(--background-modifier-border);
}

.llm-chat-container::before {
	content: "";
	display: block;
	flex: 1 1 auto;
	min-height: 0;
	pointer-events: none;
}

.llm-view.is-keyboard-open .llm-chat-container {
	padding-bottom: calc(14px + var(--pa-chat-composer-height, 0px));
}

.llm-chat-container::-webkit-scrollbar {
	width: 8px;
}

.llm-chat-container::-webkit-scrollbar-track {
	background: var(--background-primary);
	border-radius: 4px;
}

.llm-chat-container::-webkit-scrollbar-thumb {
	background: var(--background-modifier-border);
	border-radius: 4px;
}

.llm-chat-container::-webkit-scrollbar-thumb:hover {
	background: var(--text-muted);
}

.llm-message {
	box-sizing: border-box;
	margin-bottom: 12px;
	padding: 12px 14px;
	border-radius: 8px;
	max-width: 100%;
	min-width: 0;
	border: 1px solid var(--background-modifier-border);
	position: relative;
	overflow-wrap: anywhere;
}

.llm-message.llm-message-enter {
	animation: message-fade-in 160ms ease-out;
}

@keyframes message-fade-in {
	from {
		opacity: 0.96;
		transform: translateY(2px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.llm-message.user {
	background-color: var(--background-primary);
	margin-left: auto;
	max-width: min(72%, 520px);
	border-bottom-right-radius: 4px;
}

.llm-message.assistant {
	background-color: var(--background-secondary);
	margin-right: auto;
	width: min(100%, 760px);
	border-bottom-left-radius: 4px;
}

.llm-message.system {
	background-color: var(--background-primary);
	border-style: dashed;
	color: var(--text-muted);
	margin-left: auto;
	margin-right: auto;
	max-width: 92%;
}

.llm-message.system.thinking-status {
	padding: 10px 12px;
}

.llm-view .message-actions {
	position: relative;
	display: flex;
	align-items: center;
	gap: 6px;
	max-width: 100%;
	margin-top: 10px;
	color: var(--text-muted);
	opacity: 0.72;
	transition: opacity 0.16s ease;
	z-index: 2;
	--pa-chat-message-menu-arrow-left: auto;
	--pa-chat-message-menu-arrow-right: 10px;
}

.llm-view .llm-message.user .message-actions {
	justify-content: flex-end;
}

.llm-view .llm-message.assistant .message-actions,
.llm-view .llm-message.system .message-actions {
	--pa-chat-message-menu-arrow-left: 76px;
	--pa-chat-message-menu-arrow-right: auto;
}

.llm-view .llm-message:hover .message-actions,
.llm-view .llm-message:focus-within .message-actions {
	opacity: 1;
}

@media (hover: none) {
	.llm-view .message-actions {
		opacity: 1;
	}
}

.llm-view button.message-action-button {
	-webkit-appearance: none;
	appearance: none;
	box-sizing: border-box;
	background: transparent;
	background-image: none;
	border: 0;
	color: var(--text-muted);
	border-radius: 6px;
	flex: 0 0 28px;
	width: 28px;
	height: 28px;
	min-width: 28px;
	min-height: 28px;
	max-width: 28px;
	max-height: 28px;
	padding: 5px;
	display: flex;
	align-items: center;
	justify-content: center;
	cursor: pointer;
	line-height: 1;
	box-shadow: none;
	transition:
		background-color 0.16s ease,
		color 0.16s ease,
		opacity 0.16s ease,
		transform 0.12s ease;
}

.llm-view button.message-action-button:hover:not(:disabled),
.llm-view button.message-action-button:focus-visible:not(:disabled) {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.llm-view button.message-action-button:focus {
	outline: none;
}

.llm-view button.message-action-button:focus-visible:not(:disabled) {
	box-shadow: inset 0 0 0 1px var(--interactive-accent);
}

.llm-view button.message-action-button:active:not(:disabled) {
	transform: translateY(1px);
}

.llm-view button.message-action-button:disabled {
	cursor: not-allowed;
	opacity: 0.38;
}

.llm-view button.message-action-button svg {
	display: block;
	flex: 0 0 auto;
	width: 16px;
	height: 16px;
}

@media (hover: none) {
	.llm-view button.message-action-button {
		flex-basis: 44px;
		width: 44px;
		height: 44px;
		min-width: 44px;
		min-height: 44px;
		max-width: 44px;
		max-height: 44px;
		padding: 14px;
	}

	.llm-view .llm-message.assistant .message-actions,
	.llm-view .llm-message.system .message-actions {
		--pa-chat-message-menu-arrow-left: 116px;
	}

	.pa-chat-message-menu {
		min-width: 144px;
	}
}

.llm-view .message-role {
	--pa-chat-role-icon-size: 22px;
	--pa-chat-role-icon-padding: 2px;
	display: inline-flex;
	align-items: center;
	gap: 6px;
	max-width: 100%;
	color: var(--text-muted);
	font-size: 0.85em;
	font-weight: 600;
	margin-bottom: 6px;
	text-transform: uppercase;
	letter-spacing: 0;
	margin-right: 0;
}

.llm-view .pa-chat-role-text {
	line-height: 1.25;
}

.llm-view .pa-chat-role-identicon {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	flex: 0 0 var(--pa-chat-role-icon-size);
	width: var(--pa-chat-role-icon-size);
	height: var(--pa-chat-role-icon-size);
	box-sizing: border-box;
	padding: var(--pa-chat-role-icon-padding);
	border-radius: 8px;
	background: color-mix(in srgb, var(--pa-chat-role-identicon-fill) 10%, var(--background-modifier-hover));
	box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--pa-chat-role-identicon-fill) 22%, var(--background-modifier-border));
	opacity: 0.96;
	overflow: hidden;
	transform: translateY(0);
	transform-origin: center;
	transition:
		background-color 220ms ease,
		box-shadow 220ms ease,
		opacity 180ms ease,
		transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
	user-select: none;
	-webkit-user-drag: none;
}

.llm-view .pa-chat-role-identicon-fill-yellow {
	--pa-chat-role-identicon-fill: var(--pa-chat-role-identicon-yellow);
}

.llm-view .pa-chat-role-identicon-fill-orange {
	--pa-chat-role-identicon-fill: var(--pa-chat-role-identicon-orange);
}

.llm-view .pa-chat-role-identicon-fill-red {
	--pa-chat-role-identicon-fill: var(--pa-chat-role-identicon-red);
}

.llm-view .pa-chat-role-identicon-fill-purple {
	--pa-chat-role-identicon-fill: var(--pa-chat-role-identicon-purple);
}

.llm-view .pa-chat-role-identicon-fill-blue {
	--pa-chat-role-identicon-fill: var(--pa-chat-role-identicon-blue);
}

.llm-view .pa-chat-role-identicon-svg {
	display: block;
	width: 100%;
	height: 100%;
	fill: none;
	opacity: 0.94;
	shape-rendering: crispEdges;
	transform: translateY(0);
	transform-origin: center;
	transition:
		opacity 200ms ease,
		transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
}

.llm-view .pa-chat-role-identicon-cell {
	fill: var(--pa-chat-role-identicon-fill);
}

.llm-view .pa-chat-role-identicon-empty-scan {
	opacity: 0;
}

.llm-message[aria-busy="true"] .pa-chat-role-identicon-assistant {
	background: color-mix(in srgb, var(--pa-chat-role-identicon-fill) 18%, var(--background-modifier-active));
	box-shadow:
		inset 0 0 0 1px color-mix(in srgb, var(--pa-chat-role-identicon-fill) 55%, var(--background-modifier-border)),
		0 0 0 2px color-mix(in srgb, var(--pa-chat-role-identicon-fill) 18%, transparent);
	opacity: 1;
	transform: translateY(-1px);
}

.llm-message[aria-busy="true"] .pa-chat-role-identicon-assistant .pa-chat-role-identicon-svg {
	opacity: 1;
	transform: translateY(-0.5px);
}

.llm-view .pa-chat-role-identicon-active .pa-chat-role-identicon-empty-scan {
	animation: pa-chat-role-identicon-empty-scan 1.4s step-end infinite;
}

.llm-view .pa-chat-role-identicon-active .pa-chat-role-identicon-filled-scan {
	animation: pa-chat-role-identicon-filled-scan 1.4s step-end infinite;
}

.llm-view .pa-chat-role-identicon-scan-row-0 {
	animation-delay: 0ms;
}

.llm-view .pa-chat-role-identicon-scan-row-1 {
	animation-delay: 280ms;
}

.llm-view .pa-chat-role-identicon-scan-row-2 {
	animation-delay: 560ms;
}

.llm-view .pa-chat-role-identicon-scan-row-3 {
	animation-delay: 840ms;
}

.llm-view .pa-chat-role-identicon-scan-row-4 {
	animation-delay: 1120ms;
}

@keyframes pa-chat-role-identicon-empty-scan {
	0%,
	20% {
		opacity: 1;
	}

	20.001%,
	100% {
		opacity: 0;
	}
}

@keyframes pa-chat-role-identicon-filled-scan {
	0%,
	20% {
		opacity: 0;
	}

	20.001%,
	100% {
		opacity: 1;
	}
}

@starting-style {
	.llm-message.llm-message-enter .pa-chat-role-identicon {
		opacity: 0.72;
		transform: translateY(3px);
	}

	.llm-message.llm-message-enter .pa-chat-role-identicon .pa-chat-role-identicon-svg {
		opacity: 0.78;
		transform: translateY(1px);
	}
}

.llm-view .pa-chat-role-loader {
	--pa-chat-loader-color-rose: #e84466;
	--pa-chat-loader-color-orange: #e89a2a;
	--pa-chat-loader-color-lime: #48c25e;
	--pa-chat-loader-color-cyan: #2ab8e0;
	--pa-chat-loader-color-violet: #b06de0;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	flex: 0 0 auto;
	color: var(--pa-chat-loader-color-rose);
	opacity: 0.9;
	transform: translateY(-1px);
}

.llm-view .pa-chat-role-loader-thinking {
	width: 16px;
	height: 16px;
	animation: pa-chat-loader-color-cycle 10s linear infinite;
}

.llm-view .pa-chat-role-loader-element {
	display: inline-flex;
	flex: 0 0 auto;
}

.llm-view .pa-chat-role-loader-fallback {
	display: none;
	align-items: center;
	gap: 3px;
	height: 10px;
}

.llm-view .pa-chat-role-loader-fallback span {
	width: 3px;
	height: 3px;
	border-radius: 999px;
	background: currentColor;
	opacity: 0.55;
	animation: pa-chat-loader-dot 1.2s ease-in-out infinite;
}

.llm-view .pa-chat-role-loader-fallback span:nth-child(2) {
	animation-delay: 0.15s;
}

.llm-view .pa-chat-role-loader-fallback span:nth-child(3) {
	animation-delay: 0.3s;
}

.llm-view .pa-chat-role-loader .pa-chat-role-loader-element:not(:defined) + .pa-chat-role-loader-fallback {
	display: inline-flex;
}

@keyframes pa-chat-loader-dot {
	0%,
	100% {
		opacity: 0.35;
		transform: translateY(0);
	}
	50% {
		opacity: 0.95;
		transform: translateY(-2px);
	}
}

@keyframes pa-chat-loader-color-cycle {
	0%,
	100% {
		color: var(--pa-chat-loader-color-rose);
	}
	20% {
		color: var(--pa-chat-loader-color-orange);
	}
	40% {
		color: var(--pa-chat-loader-color-lime);
	}
	60% {
		color: var(--pa-chat-loader-color-cyan);
	}
	80% {
		color: var(--pa-chat-loader-color-violet);
	}
}

.llm-view .thinking-status-header {
	display: flex;
	align-items: center;
	gap: 8px;
	justify-content: flex-start;
	min-width: 0;
}

.llm-view .thinking-status-header > button.thinking-status-toggle {
	appearance: none;
	display: flex;
	align-items: center;
	justify-content: center;
	flex: 0 0 22px;
	width: 22px;
	min-width: 22px;
	max-width: 22px;
	height: 22px;
	min-height: 22px;
	max-height: 22px;
	margin: 0;
	padding: 2px;
	border: 1px solid transparent;
	border-radius: 4px;
	background: transparent;
	color: var(--text-muted);
	box-shadow: none;
	cursor: pointer;
	font-size: 0;
	line-height: 1;
}

.llm-view .thinking-status-header > button.thinking-status-toggle:hover {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.llm-view .thinking-status-header > button.thinking-status-toggle > svg.svg-icon {
	display: block;
	flex: 0 0 14px;
	width: 14px;
	min-width: 14px;
	max-width: 14px;
	height: 14px;
	min-height: 14px;
	max-height: 14px;
	margin: 0;
	color: currentColor;
	stroke: currentColor;
}

.llm-view .thinking-status-role {
	flex: 0 0 auto;
	width: auto;
	max-width: none;
	margin: 0;
	color: var(--text-normal);
	font-size: 0.85em;
	font-weight: 700;
	letter-spacing: 0;
}

.llm-view .thinking-status-summary {
	flex: 1 1 auto;
	min-width: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
	color: var(--text-muted);
	font-size: 0.85em;
	font-weight: 400;
	line-height: 1.35;
}

.llm-view .thinking-status-details {
	display: flex;
	flex-direction: column;
	gap: 10px;
	margin-top: 8px;
	padding-top: 8px;
	border-top: 1px solid var(--background-modifier-border);
}

.llm-view .thinking-status-details[hidden] {
	display: none;
}

.llm-view .thinking-status-section {
	display: flex;
	flex-direction: column;
	gap: 6px;
	min-width: 0;
}

.llm-view .thinking-status-section-title {
	color: var(--text-faint);
	font-size: 0.78em;
	font-weight: 700;
	letter-spacing: 0;
	text-transform: uppercase;
}

.llm-view .thinking-status-detail-item {
	color: var(--text-muted);
	font-size: 0.9em;
	line-height: 1.4;
	overflow-wrap: anywhere;
}

.llm-view .thinking-status-reasoning-content {
	max-height: 220px;
	overflow-y: auto;
	white-space: pre-wrap;
	overflow-wrap: anywhere;
	color: var(--text-muted);
	font-size: 0.9em;
	line-height: 1.45;
}

.llm-view .thinking-status-context-list {
	display: flex;
	flex-direction: column;
	gap: 6px;
	min-width: 0;
}

.llm-view .thinking-status-context-item {
	display: grid;
	grid-template-columns: minmax(0, 1fr);
	gap: 3px;
	padding: 7px 8px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-primary);
}

.llm-view .thinking-status-context-label {
	color: var(--text-normal);
	font-size: 0.9em;
	font-weight: 650;
	line-height: 1.3;
}

.llm-view .thinking-status-context-detail,
.llm-view .thinking-status-context-sources,
.llm-view .thinking-status-context-note {
	color: var(--text-muted);
	font-size: 0.82em;
	line-height: 1.35;
	overflow-wrap: anywhere;
}

.llm-view .thinking-status-context-note {
	color: var(--text-faint);
}

.llm-view .message-content {
	box-sizing: border-box;
	margin-top: 6px;
	line-height: 1.5;
	color: var(--text-normal);
	min-width: 0;
	max-width: 100%;
	overflow-x: hidden;
}

.llm-view .message-content p:first-child {
	margin-top: 0;
}

.llm-view .message-content p:last-child {
	margin-bottom: 0;
}

.llm-view .message-content pre {
	background: var(--background-primary);
	border-radius: 6px;
	padding: 12px;
	margin: 8px 0;
}

.llm-view .message-content code {
	font-family: var(--font-monospace);
	font-size: 0.9em;
}

.llm-view .message-content pre code {
	display: block;
	overflow-x: auto;
	padding: 0.5em;
	background: var(--background-primary);
	border: 1px solid var(--background-modifier-border);
	border-radius: 4px;
}

.llm-view .message-render-buffer {
	box-sizing: border-box;
	min-width: 0;
	width: 100%;
	max-width: 100%;
	overflow-x: hidden;
}

.llm-view .pa-chat-mermaid-shell {
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
	min-width: 0;
	width: 100%;
	max-width: 100%;
	margin: 10px 0;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-primary);
	overflow: hidden;
}

.llm-view .pa-chat-mermaid-toolbar {
	display: flex;
	flex: 0 0 auto;
	justify-content: flex-end;
	min-width: 0;
	padding: 6px 6px 0;
}

.llm-view .pa-chat-mermaid-viewport {
	box-sizing: border-box;
	min-width: 0;
	width: 100%;
	max-width: 100%;
	max-height: min(58vh, 460px);
	overflow-x: auto;
	overflow-y: auto;
	-webkit-overflow-scrolling: touch;
	overscroll-behavior: contain;
	padding: 8px 12px 12px;
	touch-action: pan-x pan-y;
}

.llm-view .pa-chat-mermaid-viewport > .mermaid,
.llm-view .pa-chat-mermaid-viewport > .block-language-mermaid {
	display: block;
	max-width: none;
	min-width: 100%;
	width: max-content;
}

.llm-view .pa-chat-mermaid-viewport svg {
	display: block;
	max-width: none;
	min-width: 100%;
}

body.is-mobile .llm-view .pa-chat-mermaid-shell,
body.is-mobile .llm-view .pa-chat-mermaid-viewport {
	max-width: 100%;
}

.llm-view .pa-chat-mermaid-open-button {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 32px;
	height: 32px;
	min-width: 32px;
	min-height: 32px;
	padding: 0;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-primary);
	color: var(--text-muted);
	box-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
	cursor: pointer;
}

.llm-view .pa-chat-mermaid-open-button:hover {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.llm-view .pa-chat-mermaid-open-button svg {
	width: 15px;
	height: 15px;
}

.llm-view.is-narrow .pa-chat-mermaid-open-button {
	width: 40px;
	height: 40px;
	min-width: 40px;
	min-height: 40px;
}

.llm-view .pa-chat-render-warning {
	margin-top: 8px;
	padding: 7px 9px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
	background: var(--background-secondary);
	color: var(--text-muted);
	font-size: 0.85em;
	line-height: 1.35;
}

.pa-chat-mermaid-modal {
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
	gap: 10px;
	width: min(92vw, 1200px);
	max-width: 92vw;
	min-width: 0;
}

.pa-chat-mermaid-modal-shell {
	box-sizing: border-box;
	width: min(94vw, 1280px);
	max-width: 94vw;
	min-width: 0;
}

.pa-chat-mermaid-modal h2 {
	margin: 0;
	font-size: 1.1em;
}

.pa-chat-mermaid-modal-viewport {
	box-sizing: border-box;
	min-width: 0;
	width: 100%;
	max-width: 100%;
	max-height: min(72vh, calc(100vh - 180px));
	overflow-x: auto;
	overflow-y: auto;
	-webkit-overflow-scrolling: touch;
	overscroll-behavior: contain;
	padding: 14px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-primary);
	touch-action: pan-x pan-y;
}

.pa-chat-mermaid-modal-diagram {
	display: block;
	max-width: none;
	min-width: 100%;
	width: max-content;
}

.pa-chat-mermaid-modal-diagram svg {
	display: block;
	max-width: none;
	min-width: 100%;
}

.llm-input {
	position: relative;
	flex: 0 0 auto;
	padding: 12px 12px calc(12px + var(--pa-chat-status-bar-clearance, 0px));
	background: var(--background-primary);
	border-top: 1px solid var(--background-modifier-border);
	transform: translate3d(0, 0, 0);
	transition: transform var(--pa-chat-keyboard-motion);
	z-index: 3;
}

.llm-view.is-keyboard-open .llm-input {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	transform: translate3d(0, var(--pa-chat-keyboard-offset, 0px), 0);
	will-change: transform;
	z-index: 30;
}

.pa-chat-composer-row {
	position: relative;
	display: block;
	border: 1px solid var(--background-modifier-border);
	border-radius: 12px;
	background: var(--background-primary);
	transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.llm-input textarea {
	width: 100%;
	border: 0;
	border-radius: 12px;
	margin: 0;
	padding: 12px 12px 58px;
	resize: none;
	background: transparent;
	color: var(--text-normal);
	font-size: 1em;
	line-height: 1.5;
	min-height: 132px;
	box-shadow: none;
	transition: color 0.2s ease;
}

body.is-mobile .llm-input {
	position: relative;
	left: auto;
	right: auto;
	bottom: auto;
	flex: 0 0 auto;
	padding: 8px 8px calc(8px + var(--pa-chat-status-bar-clearance, 0px));
	transform: translate3d(0, 0, 0);
	transition: none;
	will-change: auto;
	z-index: 3;
}

body.is-mobile .llm-view.is-keyboard-open .llm-input {
	position: relative;
	left: auto;
	right: auto;
	bottom: auto;
	transform: translate3d(0, 0, 0);
	will-change: auto;
	z-index: 3;
}

body.is-mobile .llm-view.is-keyboard-open .llm-chat-container {
	padding-bottom: 14px;
}

body.is-mobile .llm-input textarea {
	box-sizing: border-box;
	height: 72px;
	min-height: 72px;
	max-height: min(26vh, 124px);
	overflow-y: auto;
	padding: 8px 10px 42px;
	-webkit-overflow-scrolling: touch;
}

body.is-mobile .llm-buttons {
	gap: 4px;
	right: 7px;
	bottom: 7px;
}

.pa-chat-composer-row:focus-within {
	border-color: var(--text-normal);
	box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.1);
}

.llm-input textarea:focus {
	outline: none;
	box-shadow: none;
}

.llm-buttons {
	display: flex;
	gap: 6px;
	flex-wrap: nowrap;
	align-items: center;
	justify-content: flex-end;
	margin: 0;
	position: absolute;
	right: 10px;
	bottom: 10px;
	max-width: calc(100% - 20px);
}

.llm-buttons button {
	padding: 4px 8px;
	border-radius: 4px;
	font-weight: 500;
	transition: all 0.2s ease;
	background-color: var(--background-modifier-border);
	color: var(--text-normal);
	border: 1px solid var(--background-modifier-border);
	cursor: pointer;
	font-size: 0.85em;
	white-space: nowrap;
}

.llm-buttons button:hover:not(:disabled) {
	background-color: var(--background-secondary);
	border-color: var(--text-muted);
}

.llm-buttons button:active:not(:disabled) {
	transform: translateY(1px);
	background-color: var(--background-modifier-border);
}

.llm-buttons button.cancel-button {
	width: 30px;
	height: 30px;
	padding: 0;
	border-radius: 7px;
	font-weight: bold;
	background-color: var(--background-modifier-border);
	color: var(--text-muted);
	display: flex;
	align-items: center;
	justify-content: center;
	line-height: 1;
}

.llm-buttons button:disabled {
	opacity: 0.6;
	cursor: not-allowed;
	transform: none;
}

.theme-dark .llm-message.user {
	background-color: var(--background-secondary-alt);
	border-color: var(--background-modifier-border);
}

.theme-dark .llm-message.assistant {
	background-color: var(--background-secondary);
	border-color: var(--background-modifier-border);
}

.theme-dark .llm-message.system {
	background-color: var(--background-primary);
}

.llm-view .llm-buttons button.cancel-button-hidden {
	display: none;
}

.llm-view .llm-buttons button.cancel-button-visible {
	display: flex;
}

.llm-view .llm-buttons button.send-button-hidden {
	display: none;
}

.llm-view .llm-buttons button.send-button-visible {
	display: flex;
}

.pa-sr-only {
	position: absolute;
	width: 1px;
	height: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

.pa-chat-icon-button,
.llm-buttons button.pa-chat-icon-button {
	width: 30px;
	height: 30px;
	padding: 0;
	border-radius: 7px;
	display: flex;
	align-items: center;
	justify-content: center;
	flex: 0 0 30px;
	font-size: 0;
}

.pa-chat-icon-button svg,
.llm-buttons button.pa-chat-icon-button svg {
	width: 15px;
	height: 15px;
}

.pa-chat-memory-control,
.pa-chat-more-control {
	position: relative;
	display: inline-flex;
	flex: 0 0 auto;
}

.pa-chat-memory-chip,
.llm-buttons button.pa-chat-memory-chip {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	flex: 0 0 30px;
	width: 30px;
	height: 30px;
	padding: 0;
	border-radius: 7px;
	border: 1px solid var(--background-modifier-border);
	background: var(--background-secondary);
	color: var(--text-muted);
	font-size: 0;
	cursor: pointer;
}

.pa-chat-memory-chip:hover,
.llm-buttons button.pa-chat-memory-chip:hover:not(:disabled) {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.pa-chat-memory-chip svg,
.llm-buttons button.pa-chat-memory-chip svg {
	width: 15px;
	height: 15px;
}

body.is-mobile .llm-buttons button.pa-chat-icon-button {
	position: relative;
	width: 28px;
	height: 28px;
	flex: 0 0 28px;
	border-radius: 8px;
}

body.is-mobile .llm-buttons button.pa-chat-icon-button::before {
	content: "";
	position: absolute;
	inset: -8px;
	border-radius: 14px;
}

body.is-mobile .llm-buttons button.pa-chat-icon-button svg {
	width: 13px;
	height: 13px;
}

.pa-chat-composer-hint,
.pa-chat-selection-hint {
	margin-top: 6px;
	color: var(--text-muted);
	font-size: 0.85em;
	line-height: 1.35;
}

.pa-chat-composer-hint[hidden],
.pa-chat-selection-hint[hidden],
.pa-chat-skill-typeahead[hidden],
.pa-chat-menu[hidden] {
	display: none;
}

.pa-chat-skill-typeahead {
	margin-top: 6px;
	padding: 6px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-primary);
	box-shadow: 0 8px 22px rgba(0, 0, 0, 0.14);
	display: grid;
	gap: 4px;
}

.pa-chat-skill-typeahead-item {
	display: grid;
	grid-template-columns: minmax(0, 1fr) auto;
	gap: 8px;
	align-items: center;
	width: 100%;
	border: 0;
	border-radius: 6px;
	background: transparent;
	color: var(--text-normal);
	cursor: pointer;
	font-size: 0.86em;
	line-height: 1.3;
	padding: 7px 8px;
	text-align: left;
}

.pa-chat-skill-typeahead-item:hover,
.pa-chat-skill-typeahead-item:focus-visible {
	background: var(--background-modifier-hover);
	outline: none;
}

.pa-chat-skill-typeahead-name,
.pa-chat-skill-typeahead-id {
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.pa-chat-skill-typeahead-id {
	color: var(--text-muted);
	font-family: var(--font-monospace);
	font-size: 0.85em;
}

.pa-chat-menu {
	position: absolute;
	right: 0;
	bottom: calc(100% + 10px);
	min-width: 244px;
	max-width: min(300px, calc(100vw - 24px));
	padding: 7px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 14px;
	background: var(--background-primary);
	box-shadow:
		0 18px 38px rgba(0, 0, 0, 0.22),
		0 4px 12px rgba(0, 0, 0, 0.12);
	z-index: 20;
}

.pa-chat-menu::after {
	content: "";
	position: absolute;
	right: 18px;
	bottom: -6px;
	width: 11px;
	height: 11px;
	border-right: 1px solid var(--background-modifier-border);
	border-bottom: 1px solid var(--background-modifier-border);
	background: var(--background-primary);
	transform: rotate(45deg);
	pointer-events: none;
}

.pa-chat-message-menu {
	top: auto;
	bottom: calc(100% + 8px);
	right: 0;
	min-width: 96px;
	max-width: min(132px, calc(100vw - 24px));
	padding: 3px;
	border-radius: 9px;
	box-shadow:
		0 14px 28px rgba(0, 0, 0, 0.18),
		0 3px 10px rgba(0, 0, 0, 0.1);
}

.llm-view .llm-message.assistant .pa-chat-message-menu,
.llm-view .llm-message.system .pa-chat-message-menu {
	right: auto;
	left: 0;
}

.pa-chat-message-menu::after {
	top: auto;
	right: var(--pa-chat-message-menu-arrow-right);
	left: var(--pa-chat-message-menu-arrow-left);
	bottom: -6px;
	border: 0;
	border-right: 1px solid var(--background-modifier-border);
	border-bottom: 1px solid var(--background-modifier-border);
}

.pa-chat-message-menu.pa-chat-message-menu-below {
	top: calc(100% + 8px);
	bottom: auto;
}

.pa-chat-message-menu.pa-chat-message-menu-below::after {
	top: -6px;
	bottom: auto;
	border: 0;
	border-top: 1px solid var(--background-modifier-border);
	border-left: 1px solid var(--background-modifier-border);
}

.pa-chat-memory-menu {
	right: 0;
	left: auto;
	min-width: 260px;
}

.pa-chat-menu-label {
	display: grid;
	grid-template-columns: 18px minmax(0, 1fr);
	min-height: 38px;
	align-items: center;
	gap: 0 10px;
	padding: 0 11px;
	color: var(--text-normal);
	font-size: 0.95em;
	font-weight: 650;
	line-height: 1.2;
	text-align: left;
	white-space: nowrap;
}

.pa-chat-menu-label-icon,
.pa-chat-menu-item-icon {
	display: inline-flex;
	width: 18px;
	height: 18px;
	flex: 0 0 18px;
	align-items: center;
	justify-content: center;
	justify-self: start;
	color: var(--text-muted);
}

.pa-chat-menu-label-text,
.pa-chat-menu-item-text {
	min-width: 0;
	text-align: left;
}

.pa-chat-menu-label-icon svg,
.pa-chat-menu-item-icon svg {
	width: 18px;
	height: 18px;
}

.pa-chat-menu-divider {
	height: 1px;
	margin: 7px 10px;
	background: var(--background-modifier-border);
	opacity: 0.72;
}

.pa-chat-menu .pa-chat-menu-item {
	box-sizing: border-box;
	display: grid;
	grid-template-columns: 18px minmax(0, 1fr);
	min-height: 38px;
	width: 100%;
	align-items: center;
	gap: 0 10px;
	padding: 0 11px;
	border: 0;
	border-radius: 10px;
	background: transparent;
	background-color: transparent;
	box-shadow: none;
	color: var(--text-normal);
	text-align: left;
	font-size: 0.92em;
	font-weight: 560;
	line-height: 1.2;
	white-space: nowrap;
	cursor: pointer;
}

.pa-chat-message-menu .pa-chat-menu-item {
	grid-template-columns: 18px max-content;
	justify-content: center;
	padding: 0 8px;
}

.pa-chat-menu .pa-chat-menu-item:hover:not(:disabled),
.pa-chat-menu .pa-chat-menu-item:focus-visible:not(:disabled) {
	background: var(--background-modifier-hover);
	background-color: var(--background-modifier-hover);
	border: 0;
	box-shadow: none;
	color: var(--text-normal);
	outline: none;
	transform: none;
}

.pa-chat-menu .pa-chat-menu-item:focus-visible:not(:disabled) {
	box-shadow: inset 0 0 0 1px var(--interactive-accent);
}

.pa-chat-menu .pa-chat-menu-item:active:not(:disabled) {
	transform: none;
}

.pa-chat-menu .pa-chat-menu-item:disabled {
	opacity: 0.45;
	cursor: not-allowed;
}

.pa-chat-menu .pa-chat-menu-item-danger {
	color: var(--text-error);
}

.pa-chat-menu .pa-chat-menu-item-danger .pa-chat-menu-item-icon {
	color: currentColor;
}

.pa-chat-empty-state {
	box-sizing: border-box;
	display: flex;
	min-height: 100%;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	gap: 10px;
	padding: 24px 8px;
	color: var(--text-muted);
	text-align: center;
}

.pa-chat-empty-title {
	color: var(--text-normal);
	font-weight: 600;
}

.pa-chat-empty-chips {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 8px;
}

.pa-chat-empty-chip {
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-secondary);
	color: var(--text-normal);
	padding: 6px 10px;
	font-size: 0.9em;
	cursor: pointer;
}

.pa-chat-empty-chip:hover:not(:disabled) {
	background: var(--background-modifier-hover);
}

.pa-chat-empty-chip:disabled {
	opacity: 0.5;
	cursor: not-allowed;
}

.pa-chat-empty-hint {
	font-size: 0.85em;
}

.pa-chat-config-banner {
	gap: 12px;
}

.pa-chat-config-banner .pa-chat-empty-hint {
	max-width: 32em;
	font-size: 0.9em;
	color: var(--text-muted);
}

.llm-view button:focus-visible {
	outline: 2px solid var(--interactive-accent);
	outline-offset: 2px;
}

.llm-view textarea:focus-visible {
	outline: none;
}

@media (prefers-reduced-motion: reduce) {
	.llm-input {
		transition: none;
	}

	.llm-message.llm-message-enter {
		animation: none;
	}

	.llm-view .message-actions,
	.llm-view .message-action-button {
		transition: none;
	}

	.llm-view .pa-chat-role-loader-thinking {
		animation: none;
		color: var(--pa-chat-loader-color-rose);
	}

	.llm-view .pa-chat-role-identicon,
	.llm-view .pa-chat-role-identicon-svg {
		transition: none;
	}

	.llm-view .pa-chat-role-identicon-empty-scan,
	.llm-view .pa-chat-role-identicon-filled-scan {
		animation: none;
	}

	.llm-message[aria-busy="true"] .pa-chat-role-identicon-assistant {
		opacity: 1;
		transform: none;
	}

	.llm-view .pa-chat-role-loader-fallback span {
		animation: none;
		opacity: 0.75;
		transform: none;
	}

	.pa-pagelet-anim-blink,
	.pa-pagelet-anim-pulse-1,
	.pa-pagelet-anim-pulse-2,
	.pa-pagelet-anim-pulse-3 {
		animation: none;
	}
}

.llm-view.is-narrow .llm-chat-container {
	padding: 10px;
}

.llm-view.is-narrow .message-actions {
	opacity: 1;
}

.llm-view.is-narrow .llm-message.user {
	max-width: min(82%, 420px);
}

.llm-view.is-compact .llm-input {
	padding: 10px 10px calc(10px + var(--pa-chat-status-bar-clearance, 0px));
}

.llm-view.is-compact .llm-message {
	padding: 10px 12px;
}

.llm-view.is-compact .message-role {
	--pa-chat-role-icon-size: 24px;
	gap: 7px;
}

.llm-view.is-compact .llm-message.user {
	max-width: 88%;
}

.llm-view.is-compact .llm-input textarea {
	min-height: 116px;
	padding-bottom: 54px;
}

body.is-mobile .llm-view.is-compact .llm-input {
	padding: 8px 8px calc(8px + var(--pa-chat-status-bar-clearance, 0px));
}

body.is-mobile .llm-view.is-compact .llm-input textarea {
	height: 66px;
	min-height: 66px;
	max-height: min(26vh, 116px);
	padding-bottom: 40px;
}

.pa-notice {
	display: inline-flex;
	align-items: center;
	flex-direction: column;
	gap: 8px;
	padding: 10px 12px;
	background: var(--background-primary);
	color: var(--text-normal);
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	box-shadow: var(--shadow-s);
	font-size: 13px;
	font-weight: 600;
}

.pa-notice__text {
	white-space: nowrap;
}

.pa-notice__icon {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 16px;
	height: 16px;
	flex: 0 0 16px;
	color: var(--interactive-accent);
}

.pa-notice__icon svg {
	width: 16px;
	height: 16px;
}

.pa-notice__header {
	display: inline-flex;
	align-items: center;
	gap: 10px;
	width: 100%;
}

.pa-notice__body {
	display: flex;
	flex-direction: column;
	gap: 6px;
	width: 100%;
	margin-top: 4px;
}

.pa-notice__body--compact {
	gap: 4px;
	margin-top: 0;
}

.pa-notice__summary {
	width: 100%;
	padding: 6px 8px;
	border-radius: 8px;
	background: var(--background-secondary);
	color: var(--text-normal);
	font-size: 12px;
	font-weight: 700;
	line-height: 1.35;
}

.pa-notice__summary--warning {
	color: var(--text-warning, var(--text-accent));
}

.pa-notice__summary--danger {
	color: var(--text-error, var(--text-accent));
}

.pa-notice__details {
	display: flex;
	flex-direction: column;
	gap: 4px;
	width: 100%;
}

.pa-notice__detail {
	display: grid;
	grid-template-columns: minmax(86px, max-content) minmax(0, 1fr);
	gap: 10px;
	align-items: start;
	width: 100%;
}

.pa-notice__detail-label,
.pa-notice__detail-value {
	font-size: 12px;
	line-height: 1.35;
}

.pa-notice__detail-label {
	color: var(--text-muted);
	font-weight: 600;
	white-space: nowrap;
}

.pa-notice__detail-value {
	color: var(--text-normal);
	font-weight: 600;
	overflow-wrap: anywhere;
}

.pa-notice__detail--warning .pa-notice__detail-value {
	color: var(--text-warning, var(--text-accent));
}

.pa-notice__detail--danger .pa-notice__detail-value {
	color: var(--text-error, var(--text-accent));
}

.pa-notice__item {
	display: inline-flex;
	align-items: center;
	gap: 8px;
	padding: 6px 8px;
	border-radius: 8px;
	background: var(--background-secondary);
	color: var(--text-normal);
	font-size: 12px;
	font-weight: 600;
}

.pa-notice__item--note {
	align-items: flex-start;
	background: var(--background-modifier-hover);
	color: var(--text-muted);
	font-weight: 500;
	line-height: 1.35;
	white-space: normal;
}

.pa-notice__item-dot {
	display: inline-block;
	width: 12px;
	height: 12px;
	border-radius: 9999px;
	background: var(--interactive-accent);
}

.pa-notice__item--active {
	background: var(--background-modifier-hover);
}

.pa-notice__item--done {
	background: var(--background-modifier-success);
}

.pa-notice__spinner {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 16px;
	height: 16px;
	position: relative;
}

.pa-notice__spinner span,
.pa-notice__spinner::before,
.pa-notice__spinner::after {
	content: "";
	position: absolute;
	width: 8px;
	height: 8px;
	border-radius: 9999px;
	background: var(--interactive-accent);
	animation: pa-bounce 1s infinite ease-in-out;
}

.pa-notice__spinner::before {
	left: -6px;
	animation-delay: -0.2s;
	opacity: 0.6;
}

.pa-notice__spinner::after {
	right: -6px;
	animation-delay: 0.2s;
	opacity: 0.6;
}

@keyframes pa-bounce {
	0%,
	100% {
		transform: translateY(0);
		opacity: 0.9;
	}
	50% {
		transform: translateY(-4px);
		opacity: 0.5;
	}
}

.pa-notice-shell {
	background: transparent;
	box-shadow: none;
	border: none;
	padding: 0;
}

.pa-notice-shell .notice-body {
	padding: 0;
}

.pa-notice--diagnostic {
	align-items: stretch;
	width: min(360px, calc(100vw - 32px));
	max-width: calc(100vw - 32px);
}

.pa-notice--diagnostic .pa-notice__text {
	white-space: normal;
}

.pa-memory-modal {
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.pa-memory-modal h2 {
	margin: 0 0 4px;
}

.pa-memory-modal__intro {
	color: var(--text-muted);
	margin: 0;
}

.pa-memory-modal__section {
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	padding: 10px 12px;
}

.pa-memory-modal__section-title {
	color: var(--text-normal);
	font-weight: 600;
	margin-bottom: 4px;
}

.pa-memory-modal__section-body,
.pa-memory-modal__details {
	color: var(--text-muted);
	font-size: 13px;
	line-height: 1.4;
}

.pa-memory-modal__details {
	display: flex;
	flex-direction: column;
	gap: 4px;
}

.pa-settings-nav {
	position: sticky;
	top: 0;
	z-index: 10;
	display: flex;
	gap: 4px;
	padding: 8px 0;
	background: var(--background-primary);
	border-bottom: 1px solid var(--background-modifier-border);
	overflow-x: auto;
	-webkit-overflow-scrolling: touch;
}
.pa-settings-nav-item {
	padding: 4px 12px;
	border: 1px solid var(--background-modifier-border);
	border-radius: var(--radius-s);
	background: var(--background-secondary);
	color: var(--text-normal);
	font-size: var(--font-small);
	cursor: pointer;
	white-space: nowrap;
	flex-shrink: 0;
}
.pa-settings-nav-item:hover { background: var(--background-modifier-hover); }
.pa-settings-nav-item:focus-visible { box-shadow: 0 0 0 2px var(--interactive-accent); }
.pa-settings-group {
	margin-bottom: 8px;
	border: 1px solid var(--background-modifier-border);
	border-radius: var(--radius-m);
	overflow: hidden;
}
.pa-settings-group-summary {
	padding: 12px 16px;
	font-weight: var(--font-semibold);
	font-size: var(--font-ui-medium);
	cursor: pointer;
	user-select: none;
	list-style: none;
	display: flex;
	align-items: center;
	gap: 8px;
	background: var(--background-secondary-alt);
}
.pa-settings-group-summary::-webkit-details-marker { display: none; }
.pa-settings-group-summary::before {
	content: "";
	display: inline-block;
	width: 0; height: 0;
	border-left: 5px solid var(--text-muted);
	border-top: 4px solid transparent;
	border-bottom: 4px solid transparent;
	transition: transform 150ms ease;
}
.pa-settings-group[open] > .pa-settings-group-summary::before {
	transform: rotate(90deg);
}
.pa-settings-group-summary:focus-visible {
	outline: 2px solid var(--interactive-accent);
	outline-offset: -2px;
}
.pa-settings-group > :not(summary) { padding: 0 16px 8px; }
body.is-mobile .pa-settings-nav { padding: 6px 0; }
body.is-mobile .pa-settings-nav-item {
	min-height: 44px;
	padding: 8px 16px;
	font-size: var(--font-ui-small);
}
body.is-mobile .pa-settings-group-summary {
	min-height: 44px;
	padding: 12px 16px;
}

.pa-settings-tab h2,
.pa-settings-tab h3 {
	margin-left: 0;
	margin-inline-start: 0;
	padding-left: 0;
	padding-inline-start: 0;
}

.pa-settings-header-link {
	font-style: italic;
}

.pa-settings-section-desc-sm {
	font-size: 14px;
}

.pa-settings-section-desc-md {
	font-size: 15px;
}

.pa-settings-resize-label {
	margin: 18px;
}

.pa-settings-tab .setting-item.pa-setting-has-form-control {
	align-items: center;
	gap: clamp(20px, 4vw, 64px);
}

.pa-settings-tab .setting-item.pa-setting-has-form-control .setting-item-info {
	flex: 1 1 auto;
	min-width: 0;
}

.pa-settings-tab .setting-item.pa-setting-has-form-control .setting-item-control {
	display: flex;
	flex: 0 0 clamp(280px, 44%, 560px);
	justify-content: flex-end;
	max-width: 560px;
	min-width: 240px;
}

.pa-settings-tab .setting-item.pa-setting-has-form-control .setting-item-control input,
.pa-settings-tab .setting-item.pa-setting-has-form-control .setting-item-control select {
	box-sizing: border-box;
	max-width: 100%;
	min-width: 0;
	width: 100%;
}

.pa-settings-tab .pa-policy-model-setting .setting-item-description {
	max-width: 62ch;
}

.pa-settings-skill-picker {
	box-sizing: border-box;
	max-width: 100%;
	min-width: min(360px, 100%);
	position: relative;
	width: min(420px, 100%);
}

.pa-settings-skill-picker__details {
	position: relative;
	width: 100%;
}

.pa-settings-skill-picker__summary {
	align-items: center;
	background: var(--background-primary);
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
	box-sizing: border-box;
	color: var(--text-normal);
	cursor: pointer;
	display: flex;
	font-size: var(--font-ui-small);
	gap: 8px;
	justify-content: space-between;
	line-height: 1.3;
	list-style: none;
	min-height: 36px;
	padding: 7px 34px 7px 10px;
	position: relative;
	width: 100%;
}

.pa-settings-skill-picker__summary::-webkit-details-marker {
	display: none;
}

.pa-settings-skill-picker__summary::after {
	border-bottom: 1.5px solid currentColor;
	border-right: 1.5px solid currentColor;
	content: "";
	height: 7px;
	opacity: 0.72;
	position: absolute;
	right: 13px;
	top: 50%;
	transform: translateY(-62%) rotate(45deg);
	transform-origin: center;
	transition: transform 120ms ease;
	width: 7px;
}

.pa-settings-skill-picker__details[open] .pa-settings-skill-picker__summary {
	border-color: var(--interactive-accent);
}

.pa-settings-skill-picker__details[open] .pa-settings-skill-picker__summary::after {
	transform: translateY(-38%) rotate(225deg);
}

.pa-settings-skill-picker__summary:focus-visible {
	box-shadow: 0 0 0 2px var(--background-primary), 0 0 0 4px var(--interactive-accent);
	outline: none;
}

.pa-settings-skill-picker__summary-text {
	min-width: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.pa-settings-skill-picker__panel {
	background: var(--background-primary);
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	box-shadow: var(--shadow-s);
	box-sizing: border-box;
	margin-top: 6px;
	max-height: min(440px, 68vh);
	overflow-y: auto;
	padding: 6px;
	width: 100%;
}

.pa-settings-skill-picker__list {
	border-top: 1px solid var(--background-modifier-border);
	margin-top: 6px;
	padding-top: 6px;
}

.pa-settings-skill-picker__option {
	align-items: flex-start;
	border-radius: 6px;
	box-sizing: border-box;
	color: var(--text-normal);
	cursor: pointer;
	display: grid;
	gap: 10px;
	grid-template-columns: 18px minmax(0, 1fr);
	padding: 8px;
	width: 100%;
}

.pa-settings-skill-picker__option:hover {
	background: var(--background-modifier-hover);
}

.pa-settings-skill-picker__option input {
	margin: 2px 0 0;
}

.pa-settings-skill-picker__option input:disabled {
	cursor: default;
}

.pa-settings-skill-picker__option.is-disabled {
	color: var(--text-muted);
	cursor: default;
}

.pa-settings-skill-picker__option--master {
	align-items: center;
	font-weight: 600;
}

.pa-settings-skill-picker__option-body {
	display: flex;
	flex-direction: column;
	gap: 2px;
	min-width: 0;
}

.pa-settings-skill-picker__option-title {
	font-size: var(--font-ui-small);
	font-weight: 600;
	line-height: 1.25;
}

.pa-settings-skill-picker__option-desc {
	color: var(--text-muted);
	font-size: var(--font-ui-smaller);
	line-height: 1.35;
}

@media (max-width: 700px) {
	.pa-settings-tab .setting-item.pa-setting-has-form-control {
		align-items: stretch;
		flex-direction: column;
		gap: 10px;
	}

	.pa-settings-tab .setting-item.pa-setting-has-form-control .setting-item-control {
		flex: 0 1 auto;
		justify-content: stretch;
		max-width: 100%;
		min-width: 0;
		width: 100%;
	}

	.pa-settings-skill-picker {
		width: 100%;
	}
}

/* Obsidian SecretComponent modal: constrain long secret names/tokens without
   replacing the native picker behavior. */
@media (min-width: 700px) {
	body.pa-settings-tab-open .modal.pa-secret-picker-modal {
		width: min(820px, calc(100vw - 96px));
		max-width: calc(100vw - 96px);
	}
}

body.pa-settings-tab-open .modal .modal-content.keychain-list-results {
	overflow-x: hidden;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key {
	box-sizing: border-box;
	display: flex;
	align-items: center;
	gap: var(--size-4-1);
	width: 100%;
	max-width: 100%;
	min-width: 0;
	overflow: hidden;
	touch-action: manipulation;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key > * {
	min-width: 0;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-content {
	flex: 1 1 auto;
	min-width: 0;
	overflow: hidden;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-title,
body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-note,
body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-secret-text,
body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-aux > :not(.clickable-icon):not(.flair) {
	min-width: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-aux {
	display: flex;
	align-items: center;
	flex: 0 0 auto;
	gap: var(--size-4-1);
	margin-left: auto;
	min-width: calc(7ch + 84px);
	max-width: none;
	overflow: hidden;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .suggestion-secret-text {
	flex: 0 1 18ch;
	max-width: min(18ch, 40vw);
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .clickable-icon {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	flex: 0 0 40px;
	width: 40px;
	height: 40px;
	pointer-events: auto;
	position: relative;
	z-index: 1;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .pa-secret-edit-action {
	color: var(--text-muted);
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .flair {
	display: none;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key.pa-secret-row-has-eye .suggestion-content {
	flex: 0 1 10ch;
	max-width: 10ch;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key.pa-secret-row-has-eye .suggestion-aux {
	flex: 1 1 auto;
	margin-left: 0;
	min-width: 0;
	max-width: 100%;
}

body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key.pa-secret-row-has-eye .suggestion-secret-text {
	flex: 1 1 auto;
	max-width: 100%;
}

@media (max-width: 600px) {
	body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key {
		gap: 2px;
	}

	body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key .clickable-icon {
		flex-basis: 40px;
		width: 40px;
		height: 40px;
	}

	body.pa-settings-tab-open .modal .suggestion-item.mod-complex.suggestion-secret-key.pa-secret-row-has-eye .suggestion-content {
		flex-basis: 8ch;
		max-width: 8ch;
	}
}

.pa-settings-nested {
	margin-left: 12px;
	padding-left: 12px;
	border-left: 2px solid var(--background-modifier-border);
}
.pa-settings-nested--level-2 {
	margin-left: 8px;
	padding-left: 8px;
	border-left-style: dashed;
}

.pa-settings-info-card {
	background: var(--background-secondary);
	border-radius: var(--radius-m);
	padding: 12px 16px;
	margin: 8px 0;
	border: 1px solid var(--background-modifier-border);
}
.pa-settings-info-card-text {
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	margin: 0 0 8px;
}
.pa-settings-info-card-list {
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	padding-left: 20px;
	margin: 0;
}
.pa-settings-info-card-list li { margin-bottom: 2px; }

/* ──────────────────────────────────────────────────────────────────────
 * Pagelet (Review Assistant) — beta settings and suggestion card baseline.
 * ────────────────────────────────────────────────────────────────────── */
.pa-pagelet-beta-callout {
	margin: 8px 0 16px;
	padding: 10px 12px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-secondary);
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	line-height: 1.4;
}

.pa-pagelet-settings-error {
	margin-top: 6px;
	color: var(--text-error);
	font-size: var(--font-ui-smaller);
	line-height: 1.35;
}

.pa-pagelet-suggestion-card {
	box-sizing: border-box;
	display: grid;
	gap: 10px;
	width: 100%;
	padding: 12px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 8px;
	background: var(--background-primary);
	color: var(--text-normal);
}

.pa-pagelet-suggestion-card__header,
.pa-pagelet-suggestion-card__footer,
.pa-pagelet-suggestion-card__badges {
	display: flex;
	align-items: center;
	gap: 8px;
	flex-wrap: wrap;
	min-width: 0;
}

.pa-pagelet-suggestion-card__kind,
.pa-pagelet-suggestion-card__badge {
	display: inline-flex;
	align-items: center;
	min-height: 22px;
	padding: 2px 7px;
	border-radius: 6px;
	background: var(--background-secondary);
	color: var(--text-muted);
	font-size: var(--font-ui-smaller);
	font-weight: 600;
	line-height: 1.2;
}

.pa-pagelet-suggestion-card__section-label {
	display: block;
	margin-bottom: 3px;
	color: var(--text-muted);
	font-size: var(--font-ui-smaller);
	font-weight: 600;
}

.pa-pagelet-suggestion-card__rationale-text,
.pa-pagelet-suggestion-card__action-text,
.pa-pagelet-suggestion-card__related-item {
	margin: 0;
	overflow-wrap: anywhere;
	line-height: 1.45;
}

.pa-pagelet-suggestion-card__related-list {
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
	align-items: center;
	margin: 0;
	padding: 0;
	list-style: none;
}

.pa-pagelet-suggestion-card__related-item {
	display: inline-flex;
	min-width: 0;
}

.pa-pagelet-suggestion-card__related-button {
	display: inline-flex;
	align-items: center;
	max-width: 100%;
	min-height: 28px;
	padding: 3px 9px;
	border: 0;
	border-radius: 6px;
	background: var(--background-secondary);
	color: var(--text-normal);
	font-size: var(--font-ui-small);
	font-weight: 500;
	line-height: 1.25;
	text-align: left;
}

.pa-pagelet-suggestion-card__related-button:hover,
.pa-pagelet-suggestion-card__related-button:focus-visible {
	background: var(--background-modifier-hover);
	color: var(--text-accent);
}

.pa-pagelet-suggestion-card__source-chip {
	display: inline-flex;
	align-items: center;
	padding: 2px 8px;
	font-size: var(--font-ui-smaller);
	background: var(--background-secondary);
	color: var(--text-muted);
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
}

.pa-pagelet-suggestion-card__source-chip--interactive {
	cursor: pointer;
}

.pa-pagelet-suggestion-card__source-chip--interactive:hover {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.pa-pagelet-suggestion-card__btn {
	border-radius: 6px;
	display: inline-flex;
	align-items: center;
	gap: 4px;
	padding: 4px 10px;
	min-height: 28px;
	font-size: var(--font-ui-smaller);
	font-weight: 500;
	cursor: pointer;
	border: 1px solid var(--background-modifier-border);
	background: var(--background-secondary);
	color: var(--text-muted);
	transition: background 0.1s ease, color 0.1s ease;
}

.pa-pagelet-suggestion-card__btn:hover {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.pa-pagelet-suggestion-card__btn--accept {
	background: var(--interactive-accent);
	color: var(--text-on-accent);
	border-color: var(--interactive-accent);
}

.pa-pagelet-suggestion-card__btn--accept:hover {
	filter: brightness(1.1);
}

.pa-pagelet-suggestion-card__btn:focus-visible,
.pa-pagelet-suggestion-card__source-chip:focus-visible {
	outline: 2px solid var(--interactive-accent);
	outline-offset: 2px;
}

.pa-pagelet-suggestion-card__footer {
	justify-content: flex-start;
	padding-top: 10px;
	border-top: 1px solid var(--background-modifier-border);
}

.pa-pagelet-suggestion-card__cost {
	margin-left: auto;
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	font-weight: 600;
	white-space: nowrap;
}

@media (max-width: 520px) {
	.pa-pagelet-suggestion-card__footer {
		align-items: stretch;
	}

	.pa-pagelet-suggestion-card__btn {
		flex: 1 1 auto;
		min-width: 92px;
	}

	.pa-pagelet-suggestion-card__cost {
		flex-basis: 100%;
		margin-left: 0;
	}
}

/* Pagelet overlay surfaces. Obsidian loads these from the generated styles.css. */
.pa-pagelet-bubble {
	position: absolute;
	z-index: 999;
	background: var(--background-secondary,#2a2a2a);
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 14px;
	padding: 18px;
	width: min(380px,calc(100vw - 32px));
	max-width: calc(100vw - 32px);
	box-shadow: 0 16px 42px rgba(0,0,0,.22),0 2px 10px rgba(0,0,0,.12);
	opacity: 0;
	transform: scale(.9) translateY(8px);
	transform-origin: bottom right;
	pointer-events: none;
	transition: opacity .22s ease,transform .22s ease;
	font-family: var(--font-interface,inherit);
	color: var(--text-normal,#dcddde);
	box-sizing: border-box;
}

.pa-pagelet-bubble[data-state=visible] {
	opacity: 1;
	transform: scale(1) translateY(0);
	pointer-events: auto;
}

.pa-pagelet-bubble-tail {
	position: absolute;
	width: 14px;
	height: 14px;
	background: var(--background-secondary,#2a2a2a);
	border-right: 1px solid var(--background-modifier-border,#3a3a3a);
	border-bottom: 1px solid var(--background-modifier-border,#3a3a3a);
	transform: rotate(45deg);
	bottom: -8px;
	left: 50%;
}

.pa-pagelet-bubble[data-placement=below] .pa-pagelet-bubble-tail {
	top: -8px;
	bottom: auto;
	border-right: none;
	border-bottom: none;
	border-left: 1px solid var(--background-modifier-border,#3a3a3a);
	border-top: 1px solid var(--background-modifier-border,#3a3a3a);
}

.pa-pagelet-bubble-header {
	display: flex;
	justify-content: flex-end;
	margin: 0;
}

.pa-pagelet-bubble-close {
	position: absolute;
	top: 12px;
	right: 12px;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	background: transparent;
	border: none;
	border-radius: 8px;
	color: var(--text-muted,#999);
	cursor: pointer;
	font-size: 18px;
	line-height: 1;
	width: 32px;
	height: 32px;
	padding: 0;
	opacity: .76;
	transition: background .15s ease,color .15s ease,opacity .15s ease;
}

.pa-pagelet-bubble-close:hover {
	background: var(--background-modifier-hover,#3a3a3a);
	opacity: 1;
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-bubble-close:focus-visible,
.pa-pagelet-bubble-source-link:focus-visible,
.pa-pagelet-bubble-btn:focus-visible {
	outline: 2px solid var(--interactive-accent,#7f6df2);
	outline-offset: 2px;
}

.pa-pagelet-bubble-items {
	list-style: none;
	margin: 2px 0 14px;
	padding: 0 42px 0 0;
	max-height: min(320px,45vh);
	overflow-y: auto;
	scrollbar-gutter: stable;
}

.pa-pagelet-bubble-items li {
	display: grid;
	grid-template-columns: 9px minmax(0,1fr);
	align-items: start;
	column-gap: 10px;
	margin-bottom: 10px;
	font-size: 13.5px;
	line-height: 1.45;
	color: var(--text-normal,#dcddde);
	min-width: 0;
}

.pa-pagelet-bubble-items li:last-child {
	margin-bottom: 0;
}

.pa-pagelet-bubble-bullet {
	flex-shrink: 0;
	width: 7px;
	height: 7px;
	border-radius: 50%;
	background: color-mix(in srgb,var(--interactive-accent,#7f6df2) 42%,var(--text-faint,#666));
	margin-top: 6px;
}

.pa-pagelet-bubble-item-body {
	display: flex;
	flex-direction: column;
	gap: 6px;
	min-width: 0;
}

.pa-pagelet-bubble-text {
	display: block;
	min-width: 0;
	overflow-wrap: anywhere;
}

.pa-pagelet-bubble-source-link {
	align-self: flex-start;
	max-width: 100%;
	color: var(--text-accent,#7f6df2);
	cursor: pointer;
	text-decoration: none;
	font-size: 11px;
	line-height: 1.35;
	padding: 2px 6px;
	border: 1px solid color-mix(in srgb,var(--text-accent,#7f6df2) 22%,transparent);
	border-radius: 999px;
	background: color-mix(in srgb,var(--text-accent,#7f6df2) 8%,transparent);
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.pa-pagelet-bubble-source-link:hover {
	text-decoration: underline;
}

.pa-pagelet-bubble-inline-hint {
	display: flex;
	align-items: flex-start;
	gap: 8px;
	margin: -4px 42px 12px 19px;
	color: var(--text-muted,#999);
	font-size: 12px;
	line-height: 1.35;
}

.pa-pagelet-bubble-inline-hint[hidden] {
	display: none;
}

.pa-pagelet-bubble-inline-hint-icon {
	display: inline-flex;
	flex: 0 0 auto;
	width: 15px;
	height: 15px;
	margin-top: 1px;
	color: var(--text-accent,#7f6df2);
}

.pa-pagelet-bubble-inline-hint-icon svg {
	width: 15px;
	height: 15px;
	stroke-width: 2;
}

.pa-pagelet-bubble-inline-hint-text {
	min-width: 0;
	overflow-wrap: anywhere;
}

.pa-pagelet-bubble-stack-nav {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 10px;
	margin: -2px 42px 12px 0;
}

.pa-pagelet-bubble-stack-nav[hidden] {
	display: none;
}

.pa-pagelet-bubble-stack-btn,
.pa-pagelet-bubble-stack-dot {
	border: 1px solid var(--background-modifier-border,#4a4a4a);
	background: transparent;
	color: var(--text-muted,#999);
	cursor: pointer;
}

.pa-pagelet-bubble-stack-btn {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 26px;
	height: 26px;
	border-radius: 8px;
	font-size: 18px;
	line-height: 1;
}

.pa-pagelet-bubble-stack-btn:disabled {
	opacity: .35;
	cursor: default;
}

.pa-pagelet-bubble-stack-dots {
	display: inline-flex;
	align-items: center;
	gap: 6px;
}

.pa-pagelet-bubble-stack-dot {
	position: relative;
	width: 28px;
	height: 28px;
	padding: 0;
	border: 0;
	border-radius: 50%;
	background: transparent;
}

.pa-pagelet-bubble-stack-dot::before {
	content: "";
	position: absolute;
	top: 50%;
	left: 50%;
	width: 8px;
	height: 8px;
	border: 1px solid var(--background-modifier-border,#4a4a4a);
	border-radius: 50%;
	background: var(--background-modifier-border,#4a4a4a);
	transform: translate(-50%, -50%);
}

.pa-pagelet-bubble-stack-dot[aria-current=true]::before {
	border-color: var(--interactive-accent,#7f6df2);
	background: var(--interactive-accent,#7f6df2);
}

body.is-mobile .pa-pagelet-bubble-stack-btn,
body.is-mobile .pa-pagelet-bubble-stack-dot {
	min-width: 44px;
	min-height: 44px;
}

.pa-pagelet-bubble-actions {
	display: flex;
	gap: 8px;
	flex-wrap: wrap;
}

.pa-pagelet-bubble-btn {
	background: var(--background-modifier-hover,#3a3a3a);
	border: 1px solid var(--background-modifier-border,#4a4a4a);
	border-radius: 8px;
	color: var(--text-muted,#999);
	cursor: pointer;
	font-size: 12px;
	line-height: 1.2;
	padding: 6px 12px;
	transition: background .15s ease,border-color .15s ease,color .15s ease,transform .15s ease,box-shadow .15s ease;
}

.pa-pagelet-bubble-btn:hover {
	background: var(--background-modifier-border,#4a4a4a);
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-bubble-actions:not(.pa-pagelet-bubble-actions--rich) .pa-pagelet-bubble-btn.primary {
	background: var(--interactive-accent,#7f6df2);
	border-color: var(--interactive-accent,#7f6df2);
	color: var(--text-on-accent,#fff);
}

.pa-pagelet-bubble-actions:not(.pa-pagelet-bubble-actions--rich) .pa-pagelet-bubble-btn.primary:hover {
	filter: brightness(1.1);
}

.pa-pagelet-bubble-actions--rich {
	display: grid;
	grid-template-columns: 1fr;
	gap: 8px;
}

.pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn {
	display: grid;
	grid-template-columns: 32px minmax(0,1fr);
	align-items: center;
	gap: 10px;
	width: 100%;
	min-height: 50px;
	padding: 8px 10px;
	text-align: left;
	background: color-mix(in srgb,var(--background-primary,#202020) 62%,var(--background-secondary,#2a2a2a));
	border-color: color-mix(in srgb,var(--background-modifier-border,#4a4a4a) 78%,transparent);
	color: var(--text-normal,#dcddde);
	box-shadow: inset 0 0 0 1px rgba(255,255,255,.02);
}

.pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn--compact {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	justify-self: start;
	width: auto;
	min-height: 32px;
	padding: 5px 10px;
	text-align: center;
	background: transparent;
	color: var(--text-muted,#999);
	box-shadow: none;
}

.pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn:hover {
	background: var(--background-modifier-hover,#3a3a3a);
	border-color: color-mix(in srgb,var(--text-muted,#999) 32%,var(--background-modifier-border,#4a4a4a));
	transform: translateY(-1px);
	box-shadow: 0 6px 18px rgba(0,0,0,.12);
}

.pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn--compact:hover {
	background: var(--background-modifier-hover,#3a3a3a);
	border-color: var(--background-modifier-border,#4a4a4a);
	transform: none;
	box-shadow: none;
}

.pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn.primary {
	background: color-mix(in srgb,var(--interactive-accent,#7f6df2) 13%,var(--background-primary,#202020));
	border-color: color-mix(in srgb,var(--interactive-accent,#7f6df2) 48%,var(--background-modifier-border,#4a4a4a));
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn.primary:hover {
	background: color-mix(in srgb,var(--interactive-accent,#7f6df2) 18%,var(--background-primary,#202020));
}

.pa-pagelet-bubble-btn-icon {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 32px;
	height: 32px;
	border-radius: 8px;
	color: var(--text-muted,#999);
	background: var(--background-modifier-hover,#3a3a3a);
}

.pa-pagelet-bubble-btn.primary .pa-pagelet-bubble-btn-icon {
	color: var(--text-on-accent,#fff);
	background: var(--interactive-accent,#7f6df2);
}

.pa-pagelet-bubble-btn-icon svg {
	width: 16px;
	height: 16px;
	stroke-width: 2;
}

.pa-pagelet-bubble-btn-copy {
	display: flex;
	min-width: 0;
	flex-direction: column;
	gap: 2px;
}

.pa-pagelet-bubble-btn-label {
	min-width: 0;
	overflow-wrap: anywhere;
	font-size: 13px;
	font-weight: 650;
	line-height: 1.25;
}

.pa-pagelet-bubble-btn-description {
	min-width: 0;
	color: var(--text-muted,#999);
	font-size: 11.5px;
	line-height: 1.3;
	overflow-wrap: anywhere;
}

.pa-pagelet-bubble.pa-pagelet-bubble--mobile {
	left: 8px;
	right: 8px;
	bottom: calc(80px + env(safe-area-inset-bottom,0px));
	top: auto;
	width: auto;
	max-height: min(70vh,calc(100vh - 120px - env(safe-area-inset-top,0px) - env(safe-area-inset-bottom,0px)));
	overflow-y: auto;
	-webkit-overflow-scrolling: touch;
	overscroll-behavior: contain;
	border-radius: 16px 16px 12px 12px;
	transform-origin: bottom center;
}

.pa-pagelet-bubble.pa-pagelet-bubble--mobile .pa-pagelet-bubble-tail {
	display: none;
}

.pa-pagelet-bubble.pa-pagelet-bubble--mobile[data-state=visible] {
	transform: scale(1) translateY(0);
}

.pa-pagelet-bubble.pa-pagelet-bubble--mobile[data-state=hidden] {
	transform: scale(.95) translateY(16px);
}

.theme-light .pa-pagelet-bubble,[data-theme=light] .pa-pagelet-bubble {
	box-shadow: 0 8px 32px rgba(0,0,0,.12),0 2px 8px rgba(0,0,0,.08);
}

body.is-mobile .pa-pagelet-bubble .pa-pagelet-bubble-items li {
	padding: 10px 12px;
	font-size: 14px;
}

body.is-mobile .pa-pagelet-bubble .pa-pagelet-bubble-source-link {
	display: inline-flex;
	align-items: center;
	box-sizing: border-box;
	min-height: 44px;
	font-size: 12px;
	padding: 8px 12px;
	touch-action: manipulation;
}

body.is-mobile .pa-pagelet-bubble .pa-pagelet-bubble-btn {
	min-height: 44px;
	padding: 10px 18px;
	font-size: 13px;
}

body.is-mobile .pa-pagelet-bubble .pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn {
	min-height: 54px;
	padding: 10px 12px;
}

body.is-mobile .pa-pagelet-bubble .pa-pagelet-bubble-actions--rich .pa-pagelet-bubble-btn--compact {
	min-height: 44px;
	padding: 8px 14px;
}

body.is-mobile .pa-pagelet-bubble .pa-pagelet-bubble-close {
	min-width: 44px;
	min-height: 44px;
	top: 10px;
	right: 10px;
}

.pa-pagelet-panel {
	position: fixed;
	top: 0;
	right: -380px;
	width: min(380px,100vw);
	--pa-pagelet-panel-height: 100vh;
	height: var(--pa-pagelet-panel-height);
	padding-top: env(safe-area-inset-top,0px);
	padding-bottom: env(safe-area-inset-bottom,0px);
	background: var(--background-primary,#222);
	border-left: 1px solid var(--background-modifier-border,#3a3a3a);
	z-index: 900;
	transform: none;
	transition: right .35s cubic-bezier(.4,0,.2,1);
	display: flex;
	flex-direction: column;
	box-shadow: -4px 0 24px rgba(0,0,0,.4);
	font-family: var(--font-interface,inherit);
	color: var(--text-normal,#dcddde);
	box-sizing: border-box;
	--pa-conn-node-fill-0: #38bdf8;
	--pa-conn-node-stroke-0: #0369a1;
	--pa-conn-node-fill-1: #a78bfa;
	--pa-conn-node-stroke-1: #6d28d9;
	--pa-conn-node-fill-2: #34d399;
	--pa-conn-node-stroke-2: #047857;
	--pa-conn-node-fill-3: #f59e0b;
	--pa-conn-node-stroke-3: #b45309;
	--pa-conn-node-fill-4: #fb7185;
	--pa-conn-node-stroke-4: #be123c;
	--pa-conn-node-fill-5: #2dd4bf;
	--pa-conn-node-stroke-5: #0f766e;
	--pa-conn-node-fill-6: #c084fc;
	--pa-conn-node-stroke-6: #7e22ce;
	--pa-conn-node-fill-7: #84cc16;
	--pa-conn-node-stroke-7: #4d7c0f;
	--pa-conn-edge-strong: #0ea5e9;
	--pa-conn-edge-weak: rgba(14, 165, 233, 0.3);
}

@supports (height: 100dvh) {
	.pa-pagelet-panel {
		--pa-pagelet-panel-height: 100dvh;
	}
}

.pa-pagelet-panel[data-state=visible] {
	right: 0;
}

body > .tooltip {
	z-index: 9999;
}

.pa-pagelet-panel-header {
	padding: 16px 20px;
	border-bottom: 1px solid var(--background-modifier-border,#3a3a3a);
	display: flex;
	align-items: center;
	justify-content: space-between;
	flex-shrink: 0;
}

.pa-pagelet-panel-title {
	font-size: 15px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
	margin: 0;
}

.pa-pagelet-panel-header-actions {
	display: flex;
	gap: 6px;
}

.pa-pagelet-panel-icon-btn {
	width: 28px;
	height: 28px;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: transparent;
	color: var(--text-faint,#666);
	cursor: pointer;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 14px;
	transition: all .15s;
	font-family: inherit;
	padding: 0;
	line-height: 1;
}

.pa-pagelet-panel-icon-btn:hover {
	background: var(--background-modifier-hover,#3a3a3a);
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-body {
	flex: 1;
	overflow-y: auto;
	-webkit-overflow-scrolling: touch;
	overscroll-behavior: contain;
	padding: 0;
}

.pa-pagelet-panel-footer {
	padding: 12px 20px;
	border-top: 1px solid var(--background-modifier-border,#3a3a3a);
	flex-shrink: 0;
}

.pa-pagelet-panel-expand-btn {
	width: 100%;
	padding: 8px;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: transparent;
	color: var(--text-muted,#999);
	font-size: 12px;
	cursor: pointer;
	transition: all .15s;
	font-family: inherit;
}

.pa-pagelet-panel-expand-btn:hover {
	background: var(--background-modifier-hover,#3a3a3a);
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-save-btn {
	width: 100%;
	padding: 8px;
	border-radius: 6px;
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#fff);
	border: none;
	font-size: 12px;
	cursor: pointer;
	transition: all .15s;
	font-family: inherit;
	margin-bottom: 6px;
}

.pa-pagelet-panel-save-btn:hover {
	filter: brightness(1.1);
}

.pa-pagelet-panel-save-btn:disabled {
	cursor: not-allowed;
	opacity: .65;
	filter: none;
}

.pa-pagelet-panel-save-btn[aria-busy=true] {
	cursor: wait;
}

.pa-pagelet-panel-timeline {
	padding: 20px;
}

.pa-pagelet-panel-timeline-section-label {
	font-size: 11px;
	text-transform: uppercase;
	letter-spacing: .5px;
	color: var(--text-faint,#666);
	margin-bottom: 12px;
	padding-left: 24px;
}

.pa-pagelet-panel-timeline-item {
	display: flex;
	gap: 12px;
	padding: 10px 0;
	position: relative;
}

.pa-pagelet-panel-timeline-line {
	width: 24px;
	display: flex;
	flex-direction: column;
	align-items: center;
	flex-shrink: 0;
}

.pa-pagelet-panel-timeline-dot {
	width: 8px;
	height: 8px;
	border-radius: 50%;
	background: var(--text-faint,#666);
	flex-shrink: 0;
	margin-top: 5px;
}

.pa-pagelet-panel-timeline-dot--accent {
	background: var(--interactive-accent,#7c9eff);
}

.pa-pagelet-panel-timeline-connector {
	width: 1px;
	flex: 1;
	background: var(--background-modifier-border,#3a3a3a);
	margin-top: 4px;
}

.pa-pagelet-panel-timeline-content {
	flex: 1;
	min-width: 0;
}

.pa-pagelet-panel-timeline-title {
	font-size: 13px;
	font-weight: 500;
	color: var(--text-normal,#dcddde);
	margin-bottom: 2px;
}

.pa-pagelet-panel-timeline-meta {
	font-size: 11px;
	color: var(--text-faint,#666);
	margin-bottom: 6px;
}

.pa-pagelet-panel-timeline-insight {
	background: var(--background-secondary,#252525);
	border-radius: 6px;
	padding: 8px 10px;
	font-size: 12px;
	color: var(--text-muted,#999);
	margin-top: 6px;
	border-left: 2px solid var(--interactive-accent,#7c9eff);
}

.pa-pagelet-panel-timeline-actions {
	display: flex;
	gap: 6px;
	margin-top: 8px;
}

.pa-pagelet-panel-timeline-action-btn {
	padding: 3px 10px;
	border-radius: 4px;
	font-size: 11px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: transparent;
	color: var(--text-faint,#666);
	cursor: pointer;
	transition: all .15s;
	font-family: inherit;
}

.pa-pagelet-panel-timeline-action-btn:hover {
	color: var(--text-muted,#999);
	border-color: var(--text-faint,#666);
}

.pa-pagelet-panel-icon-btn:focus-visible,
.pa-pagelet-panel-save-btn:focus-visible,
.pa-pagelet-panel-expand-btn:focus-visible,
.pa-pagelet-panel-timeline-action-btn:focus-visible,
.pa-pagelet-panel-scope-range-btn:focus-visible,
.pa-pagelet-panel-scope-checkbox:focus-visible,
.pa-pagelet-panel-context-pager-summary:focus-visible,
.pa-pagelet-panel-review-queue-action:focus-visible,
.pa-pagelet-tab-review-queue-filter:focus-visible,
.pa-pagelet-panel-draft-remove:focus-visible,
.pa-pagelet-panel-draft-textarea:focus-visible {
	outline: 2px solid var(--interactive-accent,#7c9eff);
	outline-offset: 2px;
}

.pa-pagelet-panel-scope {
	margin: 16px 20px 0;
	padding: 12px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	background: var(--background-secondary,#252525);
}

.pa-pagelet-panel-scope-header,
.pa-pagelet-panel-scope-summary {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 8px;
	flex-wrap: wrap;
}

.pa-pagelet-panel-scope-title {
	font-size: 13px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-scope-count,
.pa-pagelet-panel-scope-chip {
	font-size: 11px;
	color: var(--text-muted,#999);
}

.pa-pagelet-panel-scope-ranges {
	display: grid;
	grid-template-columns: repeat(2,minmax(0,1fr));
	gap: 6px;
	margin-top: 10px;
}

.pa-pagelet-panel-scope-range-btn {
	min-height: 30px;
	padding: 5px 8px;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: transparent;
	color: var(--text-muted,#999);
	font-size: 12px;
	font-family: inherit;
	cursor: pointer;
}

.pa-pagelet-panel-scope-range-btn[data-active=true] {
	border-color: var(--interactive-accent,#7c9eff);
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#fff);
}

.pa-pagelet-panel-scope-summary {
	justify-content: flex-start;
	margin-top: 10px;
}

.pa-pagelet-panel-scope-chip {
	padding: 2px 6px;
	border-radius: 4px;
	background: var(--background-secondary-alt,#232323);
	border: 1px solid var(--background-modifier-border,#3a3a3a);
}

.pa-pagelet-panel-scope-group {
	margin-top: 12px;
}

.pa-pagelet-panel-scope-group-label {
	margin-bottom: 6px;
	font-size: 10px;
	text-transform: uppercase;
	letter-spacing: .04em;
	color: var(--text-faint,#666);
}

.pa-pagelet-panel-scope-list {
	display: flex;
	flex-direction: column;
	gap: 6px;
}

.pa-pagelet-panel-scope-row {
	display: flex;
	align-items: flex-start;
	gap: 8px;
	min-width: 0;
	padding: 6px;
	border-radius: 6px;
	background: var(--background-primary,#222);
	cursor: pointer;
}

.pa-pagelet-panel-scope-row[data-locked=true] {
	cursor: default;
	opacity: .72;
}

.pa-pagelet-panel-scope-checkbox {
	flex: 0 0 auto;
	margin-top: 2px;
}

.pa-pagelet-panel-scope-row-text {
	display: flex;
	flex-direction: column;
	gap: 2px;
	min-width: 0;
}

.pa-pagelet-panel-scope-row-title {
	font-size: 12px;
	color: var(--text-normal,#dcddde);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-scope-row-meta,
.pa-pagelet-panel-scope-empty {
	font-size: 11px;
	color: var(--text-faint,#666);
}

.pa-pagelet-panel-scope-details { margin-top: 6px; }
.pa-pagelet-panel-scope-details > summary {
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	cursor: pointer;
	list-style: none;
}
.pa-pagelet-panel-scope-details > summary::-webkit-details-marker { display: none; }
.pa-pagelet-panel-scope-details > summary::before {
	content: "\25B6";
	display: inline-block;
	margin-right: 4px;
	font-size: 0.7em;
	transition: transform 0.15s ease;
}
.pa-pagelet-panel-scope-details[open] > summary::before {
	transform: rotate(90deg);
}
.pa-pagelet-panel-scope-details > summary:focus-visible {
	outline: 2px solid var(--interactive-accent);
	outline-offset: 2px;
}

.pa-pagelet-panel-review-queue {
	margin: 12px 20px 0;
	padding: 12px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	background: var(--background-primary,#222);
}

.pa-pagelet-panel-review-queue-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 8px;
	margin-bottom: 10px;
}

.pa-pagelet-panel-review-queue-title {
	font-size: 13px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-context-pager {
	margin: 12px 20px 0;
	padding: 10px 12px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	background: var(--background-secondary,#252525);
}

.pa-pagelet-panel-context-pager-summary {
	cursor: pointer;
	font-size: 12px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-context-pager-body {
	display: flex;
	flex-direction: column;
	gap: 10px;
	margin-top: 10px;
}

.pa-pagelet-panel-context-pager-group-title {
	margin-bottom: 4px;
	font-size: 10px;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: .04em;
	color: var(--text-faint,#666);
}

.pa-pagelet-panel-context-pager-list {
	margin: 0;
	padding-left: 16px;
	color: var(--text-muted,#999);
	font-size: 11px;
	line-height: 1.5;
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-review-queue-count {
	font-size: 11px;
	color: var(--text-muted,#999);
}

.pa-pagelet-panel-review-queue-list {
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.pa-pagelet-panel-review-queue-card {
	padding: 10px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	background: var(--background-secondary,#252525);
}

.pa-pagelet-panel-review-queue-card--ai-callout {
	border-left: 3px solid var(--interactive-accent,#7c9eff);
	background: var(--background-primary-alt,#202020);
}

.pa-pagelet-panel-review-queue-card-title {
	font-size: 12px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-review-queue-card-claim {
	margin-top: 5px;
	font-size: 12px;
	line-height: 1.5;
	color: var(--text-muted,#999);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-review-queue-callout-label {
	margin-bottom: 4px;
	font-size: 11px;
	font-weight: 600;
	color: var(--text-accent,#7c9eff);
}

.pa-pagelet-panel-review-queue-card-meta {
	margin-top: 6px;
	font-size: 11px;
	color: var(--text-faint,#666);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-review-queue-card-actions {
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
	margin-top: 8px;
}

.pa-pagelet-panel-review-queue-action {
	min-height: 28px;
	padding: 4px 9px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 6px;
	background: transparent;
	color: var(--text-muted,#999);
	font-size: 11px;
	font-family: inherit;
	cursor: pointer;
}

.pa-pagelet-panel-review-queue-action:hover {
	border-color: var(--interactive-accent,#7c9eff);
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-recall-title {
	font-size: 13px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-panel-recall-count {
	font-size: 11px;
	color: var(--text-muted,#999);
}

.pa-pagelet-panel-recall-card {
	padding: 10px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	background: var(--background-secondary,#252525);
}

.pa-pagelet-panel-recall-card--candidate {
	margin-top: 8px;
}

.pa-pagelet-panel-recall-card-title {
	font-size: 12px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-recall-card-claim {
	margin-top: 5px;
	font-size: 12px;
	line-height: 1.5;
	color: var(--text-muted,#999);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-recall-card-meta {
	margin-top: 6px;
	font-size: 11px;
	color: var(--text-faint,#666);
	overflow-wrap: anywhere;
}

.pa-pagelet-panel-suggestion-card-host {
	min-width: 0;
}

.pa-pagelet-panel-draft {
	margin: 0 20px 20px;
	padding: 12px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	background: var(--background-secondary,#252525);
}

.pa-pagelet-panel-draft-title {
	font-size: 13px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
	margin-bottom: 8px;
}

.pa-pagelet-panel-draft-empty {
	font-size: 12px;
	color: var(--text-faint,#666);
}

.pa-pagelet-panel-draft-block {
	display: grid;
	grid-template-columns: minmax(0,1fr) auto;
	gap: 8px;
	align-items: start;
	margin-top: 8px;
}

.pa-pagelet-panel-draft-textarea {
	width: 100%;
	min-height: 76px;
	resize: vertical;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: var(--background-primary,#222);
	color: var(--text-normal,#dcddde);
	font-family: inherit;
	font-size: 12px;
	line-height: 1.5;
	padding: 8px;
	box-sizing: border-box;
}

.pa-pagelet-panel-draft-remove {
	min-height: 30px;
	padding: 5px 8px;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: transparent;
	color: var(--text-muted,#999);
	font-size: 11px;
	font-family: inherit;
	cursor: pointer;
}

.pa-pagelet-panel-draft-remove:hover {
	color: var(--text-normal,#dcddde);
	border-color: var(--text-faint,#666);
}

.pa-pagelet-panel-timeline-divider {
	height: 1px;
	background: var(--background-modifier-border,#3a3a3a);
	margin: 16px 0 16px 24px;
}

.pa-pagelet-panel-progress-card {
	background: var(--background-secondary,#252525);
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	padding: 14px 16px;
	margin: 20px;
	display: flex;
	align-items: center;
	gap: 10px;
	color: var(--text-muted,#999);
	font-size: 13px;
}

.pa-pagelet-panel-progress-dot {
	width: 8px;
	height: 8px;
	border-radius: 50%;
	background: var(--interactive-accent,#7c9eff);
	animation: pa-pagelet-panel-progress-pulse 1s ease-in-out infinite;
	flex-shrink: 0;
}

@keyframes pa-pagelet-panel-progress-pulse {
	0%,to {
		opacity: .45;
		transform: scale(.9);
	}

	50% {
		opacity: 1;
		transform: scale(1.15);
	}

}

.pa-pagelet-panel-card-wrap {
	padding: 0 4px;
}

.pa-pagelet-panel-summary-card {
	background: var(--background-secondary,#252525);
	border-radius: 8px;
	padding: 14px 16px;
	margin-bottom: 16px;
}

.pa-pagelet-panel-summary-title {
	font-size: 15px;
	font-weight: 500;
	color: var(--text-normal,#dcddde);
	margin-bottom: 4px;
}

.pa-pagelet-panel-summary-meta {
	font-size: 12px;
	color: var(--text-faint,#666);
}

.pa-pagelet-panel-connection-map {
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	padding: 8px;
	min-height: 230px;
	display: flex;
	align-items: center;
	justify-content: center;
	position: relative;
	background:
		linear-gradient(135deg, rgba(56,189,248,.05), rgba(244,114,182,.04) 48%, rgba(34,197,94,.04)),
		var(--background-secondary-alt,#232323);
	border-radius: 8px;
	overflow: hidden;
}

.pa-pagelet-panel-connection-graph-wrap {
	width: 100%;
	min-height: 214px;
	display: flex;
	align-items: center;
	justify-content: center;
	overflow: hidden;
}

.pa-pagelet-panel-connection-graph {
	width: min(100%,560px);
	display: block;
	height: auto;
	min-height: 210px;
	overflow: visible;
	touch-action: pan-y;
	user-select: none;
}

.pa-pagelet-panel-connection-edge {
	stroke-width: 2.2px;
	stroke-linecap: round;
	opacity: .72;
	vector-effect: non-scaling-stroke;
}

.pa-pagelet-panel-connection-edge--strong {
	stroke-width: 3px;
	opacity: .92;
}

.pa-pagelet-panel-connection-edge--weak {
	stroke-dasharray: 4 5;
	opacity: .56;
}

.pa-pagelet-panel-connection-node {
	cursor: grab;
	outline: none;
}

.pa-pagelet-panel-connection-node[data-dragging="true"] {
	cursor: grabbing;
}

.pa-pagelet-panel-connection-node-hit {
	fill: transparent;
	stroke: transparent;
	pointer-events: all;
}

.pa-pagelet-panel-connection-node-dot {
	stroke-width: .9px;
	filter: drop-shadow(0 4px 10px rgba(0,0,0,.16));
	vector-effect: non-scaling-stroke;
}

.pa-pagelet-panel-connection-node--current .pa-pagelet-panel-connection-node-dot {
	stroke-width: 1.1px;
}

.pa-pagelet-panel-connection-node-label {
	fill: var(--text-normal,#dcddde);
	font-family: var(--font-interface,inherit);
	font-size: 9.5px;
	font-weight: 650;
	letter-spacing: 0;
	paint-order: stroke;
	pointer-events: none;
	stroke: var(--background-secondary-alt,#232323);
	stroke-linejoin: round;
	stroke-width: 3.2px;
}

.pa-pagelet-panel-connection-node:focus .pa-pagelet-panel-connection-node-dot,
.pa-pagelet-panel-connection-node:hover .pa-pagelet-panel-connection-node-dot {
	filter: drop-shadow(0 0 0 rgba(0,0,0,0)) drop-shadow(0 0 8px rgba(56,189,248,.36));
}

.pa-pagelet-panel-connection-empty {
	margin: 0;
	color: var(--text-muted,#999);
	font-size: 12px;
	line-height: 1.5;
	white-space: pre-wrap;
	overflow-wrap: anywhere;
}

@media (max-width: 520px) {
	.pa-pagelet-panel-connection-map {
		min-height: 210px;
		padding: 6px;
	}

	.pa-pagelet-panel-connection-graph-wrap,
	.pa-pagelet-panel-connection-graph {
		min-height: 196px;
	}
}

.pa-pagelet-panel-summary-preview {
	background: var(--background-secondary,#252525);
	border-radius: 8px;
	padding: 16px 20px;
	margin-bottom: 16px;
	font-size: 13px;
	line-height: 1.7;
	color: var(--text-muted,#999);
}

.pa-pagelet-panel-preview-h1 {
	font-size: 16px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
	margin: 12px 0 6px;
}

.pa-pagelet-panel-preview-h2 {
	font-size: 14px;
	font-weight: 500;
	color: var(--text-normal,#dcddde);
	margin: 10px 0 4px;
}

.pa-pagelet-panel-preview-li {
	padding: 2px 0 2px 8px;
	color: var(--text-muted,#999);
}

.pa-pagelet-panel-preview-p {
	margin: 4px 0;
}

.theme-light .pa-pagelet-panel,[data-theme=light] .pa-pagelet-panel {
	box-shadow: -4px 0 24px rgba(0,0,0,.12);
}

body.is-mobile .pa-pagelet-panel {
	width: 100%;
	top: 0;
	left: 0;
	right: 0;
	border-left: none;
	border-radius: 0;
	transform: translateY(100%);
	transition: none;
}

body.is-mobile .pa-pagelet-panel[data-state=visible] {
	transform: translateY(0);
}

body.is-mobile .pa-pagelet-panel-icon-btn {
	width: 44px;
	height: 44px;
	font-size: 18px;
}

body.is-mobile .pa-pagelet-panel-save-btn {
	min-height: 44px;
	padding: 10px 16px;
	font-size: 14px;
	margin-bottom: 0;
}

body.is-mobile .pa-pagelet-panel-footer {
	padding-bottom: calc(12px + env(safe-area-inset-bottom,0px));
}

body.is-mobile .pa-pagelet-panel-header-expand-btn,
body.is-mobile .pa-pagelet-panel-expand-btn {
	display: none;
}

body.is-mobile .pa-pagelet-panel-timeline-action-btn {
	padding: 10px 16px;
	font-size: 13px;
}

body.is-mobile .pa-pagelet-panel-scope-range-btn,
body.is-mobile .pa-pagelet-suggestion-card__btn,
body.is-mobile .pa-pagelet-suggestion-card__related-button,
body.is-mobile .pa-pagelet-panel-draft-remove {
	min-height: 44px;
	padding: 10px 12px;
	font-size: 13px;
}

@keyframes pa-pagelet-pet-float {
	0%,to {
		transform: translateY(0);
	}

	50% {
		transform: translateY(-4px);
	}

}

@keyframes pa-pagelet-pet-breathe {
	0%,to {
		transform: translateY(0) rotate(-1deg) scale(1);
	}

	50% {
		transform: translateY(2px) rotate(1.4deg) scale(1.055);
	}

}

@keyframes pa-pagelet-pet-pulse {
	0%,to {
		transform: scale(1);
	}

	50% {
		transform: scale(1.04);
	}

}

@keyframes pa-pagelet-pet-review-scan {
	0%,to {
		transform: translateY(0) scale(1);
	}

	38% {
		transform: translateY(-3px) scale(1.035);
	}

	72% {
		transform: translateY(1px) scale(.99);
	}

}

@keyframes pa-pagelet-pet-connection-weave {
	0%,to {
		transform: translateX(0) rotate(0);
	}

	28% {
		transform: translateX(-3px) rotate(-3deg);
	}

	72% {
		transform: translateX(3px) rotate(3deg);
	}

}

@keyframes pa-pagelet-pet-summary-page {
	0%,to {
		transform: translateY(0) scaleY(1);
	}

	42% {
		transform: translateY(-2px) scaleY(.94);
	}

	68% {
		transform: translateY(1px) scaleY(1.06);
	}

}

@keyframes pa-pagelet-pet-task-ring {
	0%,to {
		opacity: .16;
		transform: scale(.94);
	}

	50% {
		opacity: .38;
		transform: scale(1.08);
	}

}

@keyframes pa-pagelet-pet-bounce {
	0%,to {
		transform: translateY(0);
	}

	25% {
		transform: translateY(-8px);
	}

	45% {
		transform: translateY(-2px);
	}

	65% {
		transform: translateY(-6px);
	}

	85% {
		transform: translateY(-1px);
	}

}

@keyframes pa-pagelet-pet-blink {
	0%,92%,to {
		transform: scaleY(1);
	}

	95% {
		transform: scaleY(.1);
	}

}

@keyframes pa-pagelet-pet-dot-pulse {
	0%,to {
		opacity: 1;
		transform: scale(1);
	}

	50% {
		opacity: .3;
		transform: scale(.72);
	}

}

@keyframes pa-pagelet-pet-nudge-dot-glow {
	0%,to {
		box-shadow: 0 0 4px var(--pagelet-done,#5dd39e);
		transform: scale(1);
	}

	50% {
		box-shadow: 0 0 12px var(--pagelet-done,#5dd39e),0 0 24px rgba(93,211,158,.35);
		transform: scale(1.15);
	}

}

@keyframes pa-pagelet-pet-zzz-float-1 {
	0% {
		transform: translate(0) scale(1);
		opacity: .9;
	}

	to {
		transform: translate(5px,-18px) scale(.74);
		opacity: 0;
	}

}

@keyframes pa-pagelet-pet-zzz-float-2 {
	0% {
		transform: translate(0) scale(1);
		opacity: .72;
	}

	to {
		transform: translate(8px,-24px) scale(.64);
		opacity: 0;
	}

}

@media (prefers-reduced-motion: reduce) {
	.pa-pagelet-pet-svg-wrap,
	.pa-pagelet-pet-wrapper::before,
	.pa-pagelet-pet-notification {
		animation-duration: 0s !important;
		animation-iteration-count: 1 !important;
	}
}

.pa-pagelet-pet {
	position: absolute;
	z-index: 1000;
	cursor: pointer;
	touch-action: manipulation;
	-moz-user-select: none;
	user-select: none;
	-webkit-user-select: none;
	transition: filter .4s ease,opacity .4s ease;
	--pa-pagelet-pet-task-color: #4f73e6;
}

.pa-pagelet-pet:focus-visible {
	outline: 2px solid var(--interactive-accent,#7c9eff);
	outline-offset: 3px;
	border-radius: 10px;
}

.pa-pagelet-pet[data-corner=bottom-right] {
	bottom: 36px;
	right: 20px;
}

.pa-pagelet-pet[data-corner=bottom-left] {
	bottom: 36px;
	left: 8px;
}

.pa-pagelet-pet[data-corner=top-right] {
	top: 48px;
	right: 20px;
}

.pa-pagelet-pet[data-corner=top-left] {
	top: 48px;
	left: 8px;
}

body.is-mobile .pa-pagelet-pet[data-corner=bottom-right],
body.is-mobile .pa-pagelet-pet[data-corner=bottom-left] {
	--pa-pagelet-mobile-pet-bottom-clearance: max(96px, calc(env(safe-area-inset-bottom, 0px) + 72px));
	bottom: var(--pa-pagelet-mobile-pet-bottom-clearance);
}

@media (max-width:600px) {
	body.is-mobile .pa-pagelet-pet {
		--pa-pagelet-mobile-topbar-pet-top: 59px;
		--pa-pagelet-mobile-topbar-pet-left: calc(env(safe-area-inset-left, 0px) + 60px);
		position: fixed;
		top: var(--pa-pagelet-mobile-topbar-pet-top);
		left: var(--pa-pagelet-mobile-topbar-pet-left);
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		right: auto;
		bottom: auto;
		z-index: 1002;
	}

	body.is-mobile .pa-pagelet-pet[data-corner] {
		right: auto;
		bottom: auto;
	}

	body.is-mobile .pa-pagelet-pet .pa-pagelet-pet-wrapper {
		width: 44px;
		height: 44px;
		min-width: 44px;
		min-height: 44px;
		transform: none;
		background: color-mix(in srgb,var(--background-primary) 94%,transparent);
		border: 0;
		border-radius: 999px;
		box-shadow: 0 8px 24px rgba(0,0,0,.12);
	}

	body.is-mobile .pa-pagelet-pet .pa-pagelet-pet-svg-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	body.is-mobile .pa-pagelet-pet .pa-pagelet-pet-svg-wrap svg {
		width: 28px;
		height: 28px;
	}

	body.is-mobile .pa-pagelet-pet .pa-pagelet-pet-stroke-outline {
		stroke-width: 2.8px;
	}

	body.is-mobile .pa-pagelet-pet .pa-pagelet-pet-stroke-detail {
		stroke-width: 2.35px;
	}

	body.is-mobile .pa-pagelet-pet[data-state=resting] {
		opacity: 0.8;
		filter: none;
	}

	body.is-mobile .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-svg-wrap {
		filter: none;
	}
}

.pa-pagelet-pet-wrapper {
	width: 56px;
	height: 56px;
	display: flex;
	align-items: center;
	justify-content: center;
	position: relative;
	background: transparent;
	border: 0;
	border-radius: 0;
	box-shadow: none;
}

.pa-pagelet-pet-wrapper::before,
.pa-pagelet-pet-wrapper::after {
	content: "";
	position: absolute;
	pointer-events: none;
	opacity: 0;
}

.pa-pagelet-pet-notification {
	position: absolute;
	top: -2px;
	right: -4px;
	width: 12px;
	height: 12px;
	background: var(--pagelet-done,#5dd39e);
	border-radius: 50%;
	border: 2px solid var(--background-primary,#1e1e1e);
	opacity: 0;
	transform: scale(0);
	transition: all .3s ease;
	pointer-events: none;
}

.pa-pagelet-pet[data-state=nudge] .pa-pagelet-pet-notification {
	opacity: 1;
	transform: scale(1);
	animation: pa-pagelet-pet-nudge-dot-glow 1.8s ease-in-out infinite;
}

.pa-pagelet-pet[data-capture-hold=true] {
	filter: saturate(1.12) drop-shadow(0 8px 18px rgba(20,147,107,.22));
	transform: scale(1.08);
	transition: transform .15s ease-out, filter .15s ease-out;
}

.pa-pagelet-pet[data-capture-hold=true]::after {
	content: "";
	position: absolute;
	inset: -4px;
	border: 2.5px solid rgba(20,147,107,.5);
	border-radius: 50%;
	clip-path: inset(0 0 0 0);
	animation: pa-capture-hold-ring .52s linear forwards;
	pointer-events: none;
}

@keyframes pa-capture-hold-ring {
	from { clip-path: inset(0 100% 0 0); }
	to { clip-path: inset(0 0 0 0); }
}

.pa-pagelet-pet[data-state=resting] {
	opacity: .8;
	filter: saturate(.72);
}

.pa-pagelet-pet[data-state=idle],.pa-pagelet-pet[data-state=nudge],.pa-pagelet-pet[data-state=working] {
	opacity: 1;
	filter: none;
}

.pa-pagelet-pet[data-state=idle] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-float 2.8s ease-in-out infinite;
}

.pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-breathe 3.6s ease-in-out infinite;
	transform-origin: center;
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-pulse 1.4s ease-in-out infinite;
	transform-origin: center;
}

.pa-pagelet-pet[data-state=working][data-task=review] {
	--pa-pagelet-pet-task-color: #4f73e6;
}

.pa-pagelet-pet[data-state=working][data-task=connection] {
	--pa-pagelet-pet-task-color: #14936b;
}

.pa-pagelet-pet[data-state=working][data-task=summary] {
	--pa-pagelet-pet-task-color: #c77700;
}

.pa-pagelet-pet[data-state=working][data-task=background] {
	--pa-pagelet-pet-task-color: #7c3aed;
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-wrapper::before {
	inset: 4px;
	border: 1.5px solid color-mix(in srgb,var(--pa-pagelet-pet-task-color) 72%,transparent);
	border-radius: 12px;
	box-shadow: 0 0 12px color-mix(in srgb,var(--pa-pagelet-pet-task-color) 28%,transparent);
	animation: pa-pagelet-pet-task-ring 1.45s ease-in-out infinite;
	opacity: .44;
}

.pa-pagelet-pet[data-state=working][data-task=connection] .pa-pagelet-pet-wrapper::before {
	inset: 3px;
	border-radius: 999px;
	border-style: dashed;
	animation-duration: 1.15s;
}

.pa-pagelet-pet[data-state=working][data-task=summary] .pa-pagelet-pet-wrapper::before {
	inset: 6px 8px;
	border-radius: 6px;
	animation-duration: 1.7s;
}

.pa-pagelet-pet[data-state=working][data-task=review] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-review-scan 1.25s ease-in-out infinite;
}

.pa-pagelet-pet[data-state=working][data-task=connection] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-connection-weave 1.35s ease-in-out infinite;
}

.pa-pagelet-pet[data-state=working][data-task=summary] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-summary-page 1.55s ease-in-out infinite;
}

.pa-pagelet-pet[data-state=working][data-task=background] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-pulse 1.9s ease-in-out infinite;
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-svg-wrap svg path {
	stroke: var(--pa-pagelet-pet-task-color);
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-dot {
	fill: var(--pa-pagelet-pet-task-color);
	transform-box: fill-box;
	transform-origin: center;
}

.pa-pagelet-pet[data-state=nudge] .pa-pagelet-pet-svg-wrap {
	animation: pa-pagelet-pet-bounce 1.6s ease-in-out infinite;
}

.pa-pagelet-pet[data-state=idle] .pa-pagelet-pet-blink-group,.pa-pagelet-pet[data-state=nudge] .pa-pagelet-pet-blink-group {
	animation: pa-pagelet-pet-blink 5s infinite;
	transform-origin: center;
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-dot-1 {
	animation: pa-pagelet-pet-dot-pulse 1.4s 0s infinite;
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-dot-2 {
	animation: pa-pagelet-pet-dot-pulse 1.4s .2s infinite;
}

.pa-pagelet-pet[data-state=working] .pa-pagelet-pet-dot-3 {
	animation: pa-pagelet-pet-dot-pulse 1.4s .4s infinite;
}

.pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-zzz1 {
	animation: pa-pagelet-pet-zzz-float-1 2.8s ease-out infinite;
	filter: drop-shadow(0 1px 3px rgba(0,0,0,.22));
}

.pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-zzz2 {
	animation: pa-pagelet-pet-zzz-float-2 2.8s ease-out .7s infinite;
	filter: drop-shadow(0 1px 3px rgba(0,0,0,.22));
}

.pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-sleep-zzz text {
	opacity: .76;
}

.pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-wrapper::after {
	inset: 8px;
	border-radius: 10px;
	background: color-mix(in srgb,var(--background-modifier-hover,#3a3a3a) 72%,transparent);
	opacity: .16;
}

.pa-pagelet-pet.pa-pagelet-pet--error[data-state=error] .pa-pagelet-pet-svg-wrap svg circle,
.pa-pagelet-pet.pa-pagelet-pet--error[data-state=error] .pa-pagelet-pet-svg-wrap svg path {
	stroke: #ff6b6b;
	fill: none;
}

.theme-light .pa-pagelet-pet-wrapper,[data-theme=light] .pa-pagelet-pet-wrapper {
	background: transparent;
	border: 0;
	border-radius: 0;
	box-shadow: none;
}

.theme-light .pa-pagelet-pet[data-state=resting],[data-theme=light] .pa-pagelet-pet[data-state=resting] {
	opacity: .76;
}

.theme-light .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-svg-wrap,[data-theme=light] .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-svg-wrap {
	filter: saturate(.42) brightness(.95);
}

.theme-light .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-wrapper::after,[data-theme=light] .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-wrapper::after {
	background: rgba(127,144,160,.16);
}

.theme-light .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-sleep-zzz text,[data-theme=light] .pa-pagelet-pet[data-state=resting] .pa-pagelet-pet-sleep-zzz text {
	fill: #777;
	opacity: .76;
}

.theme-light .pa-pagelet-pet[data-state=working],[data-theme=light] .pa-pagelet-pet[data-state=working] {
	opacity: 1;
	filter: none;
}

.theme-light .pa-pagelet-pet[data-state=nudge] .pa-pagelet-pet-wrapper,.theme-light .pa-pagelet-pet[data-state=working] .pa-pagelet-pet-wrapper,[data-theme=light] .pa-pagelet-pet[data-state=nudge] .pa-pagelet-pet-wrapper,[data-theme=light] .pa-pagelet-pet[data-state=working] .pa-pagelet-pet-wrapper {
	background: transparent;
	border: 0;
	border-radius: 0;
	box-shadow: none;
}

body.is-mobile .pa-pagelet-pet-wrapper {
	transform: scale(.8);
	min-width: 44px;
	min-height: 44px;
}

/* ──────────────────────────────────────────────────────────────────────
 * Pagelet Tab — zero-style anchor classes.
 *
 * The following classes are used in TabView.ts and section renderers
 * (MemoryGovernanceSection, MaintenanceReviewSection, QuietRecallSection)
 * but carry NO visual styles. They exist as semantic anchors for:
 *   - querySelector-based section navigation (tab nav scroll-to)
 *   - test selectors
 *   - user-CSS / snippet customization hooks
 *
 * Anchor classes (no rules needed — do NOT add empty rule-sets):
 *   .pa-pagelet-tab-memory-governance
 *   .pa-pagelet-tab-maintenance-review
 *   .pa-pagelet-tab-quiet-recall
 *   .pa-pagelet-tab-graph-discovery
 *   .pa-pagelet-tab-pattern-detection
 *   .pa-pagelet-tab-saved-insights
 *   .pa-pagelet-tab-context-pager
 *   .pa-pagelet-tab-memory-candidates
 *   .pa-pagelet-tab-memory-records
 *   .pa-pagelet-tab-memory-suggestions
 *   .pa-pagelet-tab-memory-candidates-empty
 *   .pa-pagelet-tab-memory-digest
 *   .pa-pagelet-tab-memory-candidate-card
 *   .pa-pagelet-tab-memory-card
 *   .pa-pagelet-tab-maintenance-overview-card
 *   .pa-pagelet-tab-maintenance-categories
 *   .pa-pagelet-tab-maintenance-category-card
 *   .pa-pagelet-tab-maintenance-empty
 *   .pa-pagelet-tab-maintenance-proposals
 *   .pa-pagelet-tab-maintenance-card
 *   .pa-pagelet-tab-recall-empty
 *   .pa-pagelet-tab-recall-card
 *   .pa-pagelet-tab-graph-empty
 *   .pa-pagelet-tab-graph-overview-card
 *   .pa-pagelet-tab-graph-items
 *   .pa-pagelet-tab-graph-card
 *   .pa-pagelet-tab-pattern-items
 *   .pa-pagelet-tab-pattern-card
 *   .pa-pagelet-tab-saved-insight-card
 *   .pa-pagelet-tab-maintenance-suggestions
 * ────────────────────────────────────────────────────────────────────── */

.pa-pagelet-tab {
	background: var(--background-primary,#1e1e1e);
	min-height: 100%;
	height: 100%;
	display: flex;
	flex-direction: column;
	font-family: var(--font-interface,inherit);
	color: var(--text-normal,#dcddde);
	box-sizing: border-box;
}

.pa-pagelet-tab-body {
	flex: 1;
	overflow-y: auto;
	padding: 32px 48px;
	max-width: 800px;
	width: 100%;
	margin: 0 auto;
	box-sizing: border-box;
}

.pa-pagelet-tab-summary-actions {
	display: flex;
	justify-content: flex-end;
	margin-bottom: 12px;
	gap: 8px;
}

.pa-pagelet-tab-summary-save {
	min-height: 36px;
	padding: 7px 14px;
	border-radius: 6px;
	border: 1px solid var(--interactive-accent,#7c9eff);
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#ffffff);
	font-size: 13px;
	font-weight: 600;
	line-height: 1.2;
	cursor: pointer;
}

.pa-pagelet-tab-summary-save:hover:not(:disabled),
.pa-pagelet-tab-summary-save:focus-visible:not(:disabled) {
	background: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
	border-color: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
}

.pa-pagelet-tab-summary-save:disabled {
	cursor: default;
	opacity: 0.75;
}

.pa-pagelet-tab-section {
	margin-bottom: 32px;
}
.pa-pagelet-tab-section--hidden {
	display: none;
}
.pa-pagelet-tab-show-more {
	display: block;
	width: 100%;
	padding: 8px 16px;
	margin-top: 8px;
	background: transparent;
	border: 1px dashed var(--background-modifier-border);
	border-radius: var(--radius-s);
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	cursor: pointer;
}
.pa-pagelet-tab-show-more:hover {
	color: var(--text-normal);
	border-color: var(--text-muted);
}
.pa-pagelet-tab-show-more:focus-visible {
	box-shadow: 0 0 0 2px var(--interactive-accent);
	outline: none;
}
body.is-mobile .pa-pagelet-tab-show-more {
	min-height: 44px;
	padding: 10px 16px;
	font-size: 13px;
}

.pa-pagelet-tab-section h2 {
	font-size: 18px;
	font-weight: 600;
	margin-bottom: 16px;
	color: var(--text-normal,#dcddde);
}

.pa-pagelet-tab-section h4 {
	font-size: 14px;
	font-weight: 500;
	color: var(--text-normal,#dcddde);
	margin-bottom: 8px;
}

.pa-pagelet-tab-review-queue-summary {
	margin: -6px 0 14px;
	color: var(--text-muted,#999);
	font-size: 13px;
	line-height: 1.6;
}

.pa-pagelet-tab-review-queue-filters {
	display: flex;
	flex-wrap: wrap;
	gap: 8px;
	margin-bottom: 16px;
}

.pa-pagelet-tab-review-queue-filter {
	min-height: 30px;
	padding: 5px 10px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 6px;
	background: transparent;
	color: var(--text-muted,#999);
	font-size: 12px;
	font-family: inherit;
	cursor: pointer;
}

.pa-pagelet-tab-review-queue-filter[data-active=true] {
	border-color: var(--interactive-accent,#7c9eff);
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#fff);
}

.pa-pagelet-tab-review-queue-group {
	margin-bottom: 20px;
}

.pa-pagelet-tab-review-queue-group h3 {
	margin: 0 0 10px;
	font-size: 13px;
	font-weight: 600;
	color: var(--text-muted,#999);
}

.pa-pagelet-tab-insight-card {
	background: var(--background-secondary-alt,#232323);
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	padding: 16px;
	margin-bottom: 12px;
}

.pa-pagelet-tab-review-queue-card--ai-callout {
	border-left: 3px solid var(--interactive-accent,#7c9eff);
	background: var(--background-primary-alt,#202020);
}

.pa-pagelet-tab-insight-card p {
	font-size: 13px;
	color: var(--text-muted,#999);
	line-height: 1.7;
	margin: 0;
}

.pa-pagelet-tab-maintenance-actions {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 8px;
	margin-top: 12px;
	min-height: 32px;
}

.pa-pagelet-tab-maintenance-action {
	min-height: 32px;
	padding: 6px 12px;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: var(--background-primary,#1e1e1e);
	color: var(--text-normal,#dcddde);
	font-size: 12px;
	font-weight: 600;
	line-height: 1.2;
	cursor: pointer;
}

.pa-pagelet-tab-maintenance-apply {
	border-color: var(--interactive-accent,#7c9eff);
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#ffffff);
}

.pa-pagelet-tab-maintenance-apply:hover:not(:disabled),
.pa-pagelet-tab-maintenance-apply:focus-visible:not(:disabled) {
	background: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
	border-color: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
}

.pa-pagelet-tab-maintenance-undo:hover:not(:disabled),
.pa-pagelet-tab-maintenance-undo:focus-visible:not(:disabled) {
	border-color: var(--text-accent,#7c9eff);
	color: var(--text-accent,#7c9eff);
}

.pa-pagelet-tab-maintenance-action:disabled {
	cursor: default;
	opacity: .75;
}

.pa-pagelet-tab-maintenance-status {
	color: var(--text-muted,#999);
	font-size: 12px;
	line-height: 1.5;
	overflow-wrap: anywhere;
}

.pa-pagelet-tab-maintenance-status[data-status=failed] {
	color: var(--text-error,#e06c75);
}

.pa-pagelet-tab-recall-actions {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 8px;
	margin-top: 14px;
	min-height: 34px;
}

.pa-pagelet-tab-recall-save {
	min-height: 36px;
	padding: 7px 12px;
	border-radius: 6px;
	border: 1px solid var(--interactive-accent,#7c9eff);
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#ffffff);
	font-size: 12px;
	font-weight: 600;
	line-height: 1.2;
	cursor: pointer;
}

.pa-pagelet-tab-recall-save:hover:not(:disabled),
.pa-pagelet-tab-recall-save:focus-visible:not(:disabled) {
	background: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
	border-color: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
}

.pa-pagelet-tab-recall-save:disabled {
	cursor: default;
	opacity: .72;
}

.pa-pagelet-tab-memory-candidates-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 10px;
	margin-bottom: 10px;
}

.pa-pagelet-tab-memory-candidate-actions {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 8px;
	margin-top: 10px;
}

.pa-pagelet-tab-memory-confirm,
.pa-pagelet-tab-memory-dismiss,
.pa-pagelet-tab-pattern-dismiss,
.pa-pagelet-tab-recall-link {
	min-height: 36px;
	padding: 6px 12px;
	border-radius: 6px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	background: var(--background-primary,#1e1e1e);
	color: var(--text-normal,#dcddde);
	font-size: 12px;
	font-weight: 600;
	line-height: 1.2;
	cursor: pointer;
}

.pa-pagelet-tab-memory-confirm:hover:not(:disabled),
.pa-pagelet-tab-memory-confirm:focus-visible:not(:disabled),
.pa-pagelet-tab-recall-link:hover:not(:disabled),
.pa-pagelet-tab-recall-link:focus-visible:not(:disabled) {
	border-color: var(--interactive-accent,#7c9eff);
	color: var(--interactive-accent,#7c9eff);
}

.pa-pagelet-tab-memory-dismiss:hover:not(:disabled),
.pa-pagelet-tab-memory-dismiss:focus-visible:not(:disabled),
.pa-pagelet-tab-pattern-dismiss:hover:not(:disabled),
.pa-pagelet-tab-pattern-dismiss:focus-visible:not(:disabled) {
	border-color: var(--text-faint,#666);
	color: var(--text-faint,#666);
}

.pa-pagelet-tab-memory-confirm-all {
	min-height: 36px;
	padding: 6px 14px;
	border-radius: 6px;
	border: 1px solid var(--interactive-accent,#7c9eff);
	background: var(--interactive-accent,#7c9eff);
	color: var(--text-on-accent,#ffffff);
	font-size: 12px;
	font-weight: 600;
	line-height: 1.2;
	cursor: pointer;
}

.pa-pagelet-tab-memory-confirm-all:hover:not(:disabled),
.pa-pagelet-tab-memory-confirm-all:focus-visible:not(:disabled) {
	background: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
	border-color: var(--interactive-accent-hover,var(--interactive-accent,#7c9eff));
}

.pa-pagelet-tab-memory-confirm:disabled,
.pa-pagelet-tab-memory-dismiss:disabled,
.pa-pagelet-tab-pattern-dismiss:disabled,
.pa-pagelet-tab-recall-link:disabled,
.pa-pagelet-tab-memory-confirm-all:disabled {
	cursor: default;
	opacity: .75;
}

.pa-pagelet-tab-memory-card--tombstone {
	opacity: 0.55;
	pointer-events: none;
}

.pa-pagelet-tab-source-link {
	padding: 2px 6px;
	border: 0;
	border-radius: 4px;
	background: none;
	color: var(--text-accent,#7c9eff);
	font-size: 12px;
	cursor: pointer;
	text-decoration: underline;
	text-decoration-color: transparent;
}

.pa-pagelet-tab-source-link:hover,
.pa-pagelet-tab-source-link:focus-visible {
	text-decoration-color: currentColor;
	background: var(--background-modifier-hover,rgba(0,0,0,.05));
}

.pa-pagelet-tab-review-queue-why {
	margin-top: 6px;
	color: var(--text-faint,#666);
	font-size: 11px;
	font-style: italic;
	line-height: 1.5;
}

.pa-pagelet-tab-maintenance-affected-paths {
	margin-top: 8px;
	color: var(--text-muted,#999);
	font-size: 11px;
	line-height: 1.6;
	overflow-wrap: anywhere;
}

.pa-pagelet-tab-muted {
	margin-top: 8px;
	color: var(--text-muted,#999);
	font-size: 12px;
	line-height: 1.6;
}

.pa-pagelet-panel-quiet-recall {
	margin: 12px 0 14px;
	padding-bottom: 12px;
	border-bottom: 1px solid var(--background-modifier-border,#3a3a3a);
}

.pa-pagelet-panel-recall-card {
	border-left: 3px solid var(--text-accent,#7c9eff);
}

.pa-pagelet-tab-review-queue-callout-label {
	display: block;
	margin-bottom: 4px;
	font-size: 11px;
	font-weight: 600;
	color: var(--text-accent,#7c9eff);
}

.pa-pagelet-tab-context-pager-list {
	margin: 0;
	padding-left: 18px;
	color: var(--text-muted,#999);
	font-size: 13px;
	line-height: 1.7;
	overflow-wrap: anywhere;
}

.pa-pagelet-tab-empty-card {
	background: var(--background-secondary-alt,#232323);
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 8px;
	padding: 20px;
}

.pa-pagelet-tab-empty-title {
	font-size: 15px;
	font-weight: 600;
	color: var(--text-normal,#dcddde);
	margin-bottom: 8px;
}

.pa-pagelet-tab-empty-body {
	font-size: 13px;
	line-height: 1.7;
	color: var(--text-muted,#999);
}

.pa-pagelet-tab-tag-row {
	display: flex;
	gap: 6px;
	margin-top: 10px;
	flex-wrap: wrap;
}

.pa-pagelet-tab-tag-chip {
	padding: 2px 8px;
	border-radius: 4px;
	font-size: 11px;
	background: var(--background-secondary,#252525);
	color: var(--text-faint,#666);
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	max-width: 100%;
	overflow-wrap: anywhere;
}

.pa-pagelet-tab-tag-chip--link {
	cursor: pointer;
	text-decoration: underline;
	background: transparent;
	border: none;
	color: var(--text-accent);
	font-size: inherit;
	padding: 0;
}
.pa-pagelet-tab-tag-chip--link:hover { color: var(--text-accent-hover); }

.pa-pagelet-tab-nav {
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
	padding: 8px 0 12px;
	position: sticky;
	top: 0;
	z-index: 1;
	background: var(--background-primary,#1e1e1e);
}

.pa-pagelet-tab-nav-item {
	appearance: none;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 12px;
	background: var(--background-primary,#1e1e1e);
	color: var(--text-muted,#999);
	font-size: 11px;
	font-weight: 500;
	padding: 4px 10px;
	cursor: pointer;
	white-space: nowrap;
}

.pa-pagelet-tab-nav-item:hover,
.pa-pagelet-tab-nav-item:focus-visible {
	border-color: var(--interactive-accent,#7c9eff);
	color: var(--interactive-accent,#7c9eff);
}

.pa-pagelet-tab-context-pager-details {
	margin-top: 16px;
	border: 1px solid var(--background-modifier-border,#3a3a3a);
	border-radius: 6px;
	overflow: hidden;
}

.pa-pagelet-tab-context-pager-details > summary {
	padding: 10px 14px;
	font-size: 13px;
	font-weight: 600;
	color: var(--text-muted,#999);
	cursor: pointer;
	list-style: none;
}

.pa-pagelet-tab-context-pager-details > summary::-webkit-details-marker {
	display: none;
}

.pa-pagelet-tab-context-pager-details > summary::before {
	content: "▸ ";
}

.pa-pagelet-tab-context-pager-details[open] > summary::before {
	content: "▾ ";
}

.pa-pagelet-tab-context-pager-details > summary:hover,
.pa-pagelet-tab-context-pager-details > summary:focus-visible {
	color: var(--text-normal,#dcddde);
}

.theme-light .pa-pagelet-tab,[data-theme=light] .pa-pagelet-tab {
	box-shadow: none;
}

@media (max-width:720px) {
	.pa-pagelet-tab-body {
		padding: 16px;
		max-width: none;
	}

}

body.is-mobile .pa-pagelet-tab-body {
	padding: 16px;
	max-width: none;
}

body.is-mobile .pa-pagelet-tab-memory-confirm,
body.is-mobile .pa-pagelet-tab-memory-dismiss,
body.is-mobile .pa-pagelet-tab-pattern-dismiss,
body.is-mobile .pa-pagelet-tab-recall-link,
body.is-mobile .pa-pagelet-tab-recall-save,
body.is-mobile .pa-pagelet-tab-memory-confirm-all,
body.is-mobile .pa-pagelet-tab-maintenance-action,
body.is-mobile .pa-pagelet-tab-review-queue-filter,
body.is-mobile .pa-pagelet-tab-nav-item {
	min-height: 44px;
	padding: 10px 14px;
}

/* ──────────────────────────────────────────────────────────────────────
 * Pagelet (Review Assistant) — mascot a11y / reduced-motion baseline.
 *
 * The mascot DOM renderer (`src/pagelet/ui/mascot/dom-renderer.ts`) emits
 * two classes the rest of the Pagelet styles assume exist:
 *
 *  - `.pa-pagelet-mascot--reduce-motion` — applied when the user has
 *    `prefers-reduced-motion: reduce` set. Disables every animation /
 *    transition under the mascot root so the SVG paths render statically.
 *  - `.pa-pagelet-mascot__live` — visually-hidden aria-live region used to
 *    announce state transitions to screen readers. Must be in the DOM
 *    (assistive tech polls it) but invisible to sighted users.
 *
 * Why a global selector for reduce-motion (rather than a per-class opt-out):
 *  - Future B5 animation work may add new `animation`/`transition` rules
 *    inside the mascot root. The wildcard `* { animation: none }` form
 *    guarantees they are caught without each new style having to opt in.
 *
 * Why the long-form visually-hidden recipe (instead of `display: none`):
 *  - `display: none` removes the element from the AT tree, so AT never
 *    sees the announcement. The clip + clip-path pattern is the WCAG-
 *    recommended way to hide content visually but keep it announceable.
 * ────────────────────────────────────────────────────────────────────── */
.pa-pagelet-mascot__live {
	position: absolute;
	width: 1px;
	height: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0 0 0 0);
	clip-path: inset(50%);
	white-space: nowrap;
	border: 0;
}

/* ──────────────────────────────────────────────────────────────────────
 * Pagelet (Review Assistant) — mascot visual tokens + animations.
 *
 * The mascot's pure markup builder (`src/pagelet/ui/mascot/markup.ts`) sets
 *   - `stroke="var(--pa-pagelet-color-<state>)"` on each path/circle, and
 *   - `class="pa-pagelet-anim-<blink|pulse-1|pulse-2|pulse-3>"` on the
 *     animated path/circle.
 *
 * The DOM renderer also sets the `--pa-pagelet-mascot-stroke` custom
 * property on the root so callers can theme the whole mascot without
 * touching state-specific tokens.
 *
 * Values mirror `docs/pagelet-visual-spec.html` §① (4-state matrix) and §②
 * (animation table). The spec uses `--pagelet-*` token names; we follow
 * the codebase's BEM-style `pa-pagelet-*` prefix instead (D013 / SDD §6.2 M1).
 *
 * Reduce-motion is honored by the global selector defined above
 * (`.pa-pagelet-mascot--reduce-motion *`) — no per-keyframe opt-out needed.
 * ────────────────────────────────────────────────────────────────────── */
.pa-pagelet-mascot {
	--pa-pagelet-color-neutral: #e8e8e8;
	--pa-pagelet-color-thinking: #7c9eff;
	--pa-pagelet-color-done: #5dd39e;
	--pa-pagelet-color-error: #ff6b6b;
}

.theme-dark .pa-pagelet-mascot {
	--pa-pagelet-color-neutral: #888888;
	--pa-pagelet-color-thinking: #8fa8ff;
	--pa-pagelet-color-done: #4ade80;
	--pa-pagelet-color-error: #f87171;
}

@keyframes pa-pagelet-mascot-blink {
	0%, 95%, 100% { transform: scaleY(1); }
	97% { transform: scaleY(0.1); }
}

@keyframes pa-pagelet-mascot-pulse {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.4; }
}

.pa-pagelet-anim-blink {
	animation: pa-pagelet-mascot-blink 4s infinite;
	transform-origin: center;
	transform-box: fill-box;
}

.pa-pagelet-anim-pulse-1 {
	animation: pa-pagelet-mascot-pulse 1.4s infinite;
}

.pa-pagelet-anim-pulse-2 {
	animation: pa-pagelet-mascot-pulse 1.4s infinite;
	animation-delay: 0.2s;
}

.pa-pagelet-anim-pulse-3 {
	animation: pa-pagelet-mascot-pulse 1.4s infinite;
	animation-delay: 0.4s;
}

@media (prefers-reduced-motion: reduce) {
	.pa-pagelet-anim-blink,
	.pa-pagelet-anim-pulse-1,
	.pa-pagelet-anim-pulse-2,
	.pa-pagelet-anim-pulse-3 {
		animation: none;
	}
}

.pa-pagelet-mascot--reduce-motion *,
.pa-pagelet-mascot--reduce-motion *::before,
.pa-pagelet-mascot--reduce-motion *::after {
	animation: none;
	transition: none;
}

.pa-write-action-modal__section-body--multiline {
	white-space: pre-line;
}

/* ──────────────────────────────────────────────────────────────────────
 * Write Action Framework — append preview layout (Phase 4 SPEC-C1).
 * ────────────────────────────────────────────────────────────────────── */
.pa-preview-append-context {
	max-height: 150px;
	overflow-y: auto;
}

.pa-preview-modal-mobile .pa-preview-append-context {
	display: none;
}

.pa-preview-modal-mobile .pa-preview-append-context.is-expanded {
	display: block;
}

.pa-write-action-modal__append-body {
	max-height: min(42vh, 420px);
	overflow-y: auto;
	overscroll-behavior: contain;
}

.pa-preview-modal-mobile .pa-write-action-modal__append-body {
	max-height: max(120px, 32vh);
}

.pa-insights-viewer {
	max-height: 70vh;
	overflow-y: auto;
}

.pa-insights-viewer__section {
	margin-bottom: 1em;
}

.pa-insights-viewer__empty {
	color: var(--text-muted);
	font-style: italic;
}

.pa-preview-append-context-toggle {
	display: inline-flex;
	align-items: center;
	margin: 6px 0;
	padding: 4px 10px;
	border: 1px solid var(--background-modifier-border);
	border-radius: 6px;
	background: var(--background-secondary);
	color: var(--text-muted);
	font-size: var(--font-ui-smaller);
	cursor: pointer;
}

.pa-preview-append-context-toggle:hover {
	background: var(--background-modifier-hover);
	color: var(--text-normal);
}

.pa-write-action-modal__append-divider {
	margin: 10px 0;
	padding: 6px 0;
	border-top: 1px dashed var(--background-modifier-border);
	color: var(--text-muted);
	font-size: var(--font-ui-smaller);
	font-weight: 600;
	text-align: center;
}

.pa-write-action-modal__append-size-warning {
	margin-top: 8px;
	padding: 8px 10px;
	border: 1px solid var(--text-error, #ef4444);
	border-radius: 6px;
	background: color-mix(in srgb, var(--text-error, #ef4444) 8%, var(--background-primary));
	color: var(--text-error, #ef4444);
	font-size: var(--font-ui-small);
	font-weight: 600;
	line-height: 1.35;
}

.pa-quick-capture-modal-shell {
	box-sizing: border-box;
	width: min(720px, calc(100vw - 32px));
	max-width: calc(100vw - 32px);
	overflow-x: hidden;
}

.pa-quick-capture-modal {
	box-sizing: border-box;
	max-width: 100%;
	overflow-x: hidden;
}

.pa-quick-capture-modal h2 {
	margin-bottom: 4px;
}
.pa-quick-capture-modal__destination {
	color: var(--text-muted);
	font-size: var(--font-ui-small);
	margin-bottom: 8px;
}

.pa-quick-capture-modal__input {
	box-sizing: border-box;
	width: 100%;
	min-height: clamp(260px, 42vh, 420px);
	max-height: min(62vh, 620px);
	padding: 10px 12px;
	font-family: var(--font-text, var(--font-interface, inherit));
	font-size: var(--font-ui-medium, 14px);
	line-height: 1.5;
	overflow-y: auto;
	overscroll-behavior: contain;
	resize: vertical;
}

.pa-quick-capture-modal__actions {
	display: flex;
	justify-content: flex-end;
	gap: 8px;
	margin-top: 12px;
	padding-top: 8px;
	position: sticky;
	bottom: 0;
	background: var(--background-primary);
}

body.is-mobile .pa-quick-capture-modal-shell {
	width: min(560px, calc(100vw - 24px));
	max-width: calc(100vw - 24px);
}

body.is-mobile .pa-quick-capture-modal__input {
	min-height: clamp(220px, 48vh, 420px);
	max-height: 62vh;
}
