{
  "compilerOptions": {
    "outDir": "dist",
    "paths": {
      "plugin": ["./src/plugin"],
      "utils": ["./src/utils"]
    },
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "importHelpers": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "lib": ["DOM", "ES2020"],
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "types": ["node", "jest"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
