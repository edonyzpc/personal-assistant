{
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": "./src",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "allowJs": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "strictPropertyInitialization": true,
    "lib": ["DOM", "ES2020"],
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules",
      "./src/types"
    ],
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
